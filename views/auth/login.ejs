<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* ── Base ────────────────────────────────────── */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #003366 0%, #0A4D8C 45%, #0077B6 100%);
            display: flex; align-items: center; justify-content: center;
            padding: 24px;
            position: relative; overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }
        h1,h2,h3,h4 { font-family: 'Plus Jakarta Sans', sans-serif; }

        /* ── Animated background orbs ────────────────── */
        .bg-orb {
            position: absolute; border-radius: 50%;
            pointer-events: none; filter: blur(80px);
        }

        /* ── Login card ──────────────────────────────── */
        .login-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 24px 64px rgba(0, 20, 60, 0.30);
            width: 100%; max-width: 420px;
            padding: 44px 40px;
            position: relative; z-index: 10;
            animation: slideUp 0.4s ease-out;
        }
        @keyframes slideUp {
            from { opacity:0; transform:translateY(24px); }
            to   { opacity:1; transform:translateY(0); }
        }
        @keyframes spin { to { transform:rotate(360deg); } }

        /* ── Brand icon ──────────────────────────────── */
        .brand-icon {
            width: 60px; height: 60px; border-radius: 16px;
            background: linear-gradient(135deg, #0A4D8C, #00ACC1);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 8px 20px rgba(10,77,140,0.30);
        }

        /* ── Form controls ───────────────────────────── */
        .form-label {
            display: block;
            font-size: 11px; font-weight: 700;
            color: #546E7A;
            text-transform: uppercase; letter-spacing: 0.06em;
            margin-bottom: 6px;
        }
        .input-wrap { position: relative; }
        .input-icon {
            position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
            color: #90A4AE; pointer-events: none;
            display: flex; align-items: center;
        }
        .form-input {
            width: 100%;
            background: #F4F7FA;
            border: 1.5px solid #CFD8DC;
            border-radius: 10px;
            padding: 11px 14px 11px 40px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #263238;
            transition: all 0.2s;
            outline: none;
        }
        .form-input:focus {
            border-color: #0A4D8C;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(10,77,140,0.10);
        }
        .form-input::placeholder { color: #B0BEC5; }

        /* ── Primary button ──────────────────────────── */
        .login-btn {
            width: 100%;
            background: linear-gradient(135deg, #0A4D8C, #0077B6);
            color: #fff;
            border: none; cursor: pointer;
            border-radius: 10px;
            padding: 13px;
            font-size: 14px; font-weight: 700;
            font-family: 'Inter', sans-serif;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            box-shadow: 0 6px 18px rgba(10,77,140,0.30);
            transition: all 0.2s;
        }
        .login-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #073B6B, #0A4D8C);
            box-shadow: 0 8px 22px rgba(10,77,140,0.40);
            transform: translateY(-1px);
        }
        .login-btn:active:not(:disabled) { transform: translateY(0); }
        .login-btn:disabled { opacity: .55; cursor: not-allowed; }

        /* ── Extras ──────────────────────────────────── */
        .remember-label {
            display: flex; align-items: center; gap: 6px;
            font-size: 13px; color: #546E7A; cursor: pointer;
        }
        .forgot-link {
            font-size: 13px; font-weight: 600;
            color: #0A4D8C; text-decoration: none;
            transition: color 0.2s;
        }
        .forgot-link:hover { color: #073B6B; text-decoration: underline; }

        .error-msg {
            background: #FFEBEE;
            border: 1.5px solid #FFCDD2;
            border-radius: 10px;
            padding: 10px 14px;
            color: #D11717;
            font-size: 13px; font-weight: 600;
            display: flex; align-items: center; gap: 8px;
        }

        .demo-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 16px;
            border-radius: 9999px;
            border: 1.5px solid #CFD8DC;
            background: #F4F7FA;
            font-size: 12px; color: #546E7A;
            cursor: pointer;
            transition: all 0.2s;
        }
        .demo-pill:hover { border-color: #0A4D8C; color: #0A4D8C; background: #E3F2FD; }
        .demo-pill strong { color: #0A4D8C; }

        .back-link {
            position: absolute; top: 24px; left: 24px;
            display: flex; align-items: center; gap: 6px;
            padding: 8px 14px; border-radius: 9999px;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.25);
            color: rgba(255,255,255,0.85);
            font-size: 13px; font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            z-index: 10;
        }
        .back-link:hover { background: rgba(255,255,255,0.25); color: #fff; }

        .spin { animation: spin 1s linear infinite; }
    </style>
</head>
<body>
    <!-- Decorative blobs -->
    <div class="bg-orb" style="width:500px;height:500px;background:rgba(0,172,193,0.15);top:-100px;right:-150px;"></div>
    <div class="bg-orb" style="width:400px;height:400px;background:rgba(76,175,80,0.08);bottom:-100px;left:-100px;"></div>

    <!-- Back to home -->
    <a href="/" class="back-link">
        <iconify-icon icon="solar:arrow-left-linear" width="15"></iconify-icon>
        Back to Home
    </a>

    <!-- Login Card -->
    <div class="login-card">

        <!-- Brand -->
        <div style="text-align:center;">
            <div class="brand-icon">
                <iconify-icon icon="solar:lock-keyhole-minimalistic-bold-duotone" width="28" style="color:#fff;"></iconify-icon>
            </div>
            <h2 style="font-size:22px;font-weight:700;color:#0A4D8C;margin-bottom:4px;">Admin Login</h2>
            <p style="font-size:13px;color:#90A4AE;margin-bottom:28px;">Welcome back! Enter your credentials to continue.</p>
        </div>

        <!-- Form – action/method/name attributes untouched -->
        <form action="/login" method="POST" id="loginForm" style="display:flex;flex-direction:column;gap:16px;">

            <!-- Username -->
            <div>
                <label class="form-label">Username</label>
                <div class="input-wrap">
                    <span class="input-icon"><iconify-icon icon="solar:user-bold" width="16"></iconify-icon></span>
                    <input type="text" name="username" id="username"
                           value="admin" class="form-input"
                           placeholder="Enter username" required>
                </div>
            </div>

            <!-- Password -->
            <div>
                <label class="form-label">Password</label>
                <div class="input-wrap">
                    <span class="input-icon"><iconify-icon icon="solar:lock-password-bold" width="16"></iconify-icon></span>
                    <input type="password" name="password" id="password"
                           value="admin123" class="form-input"
                           placeholder="••••••••" required>
                </div>
            </div>

            <!-- Remember / Forgot -->
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <label class="remember-label">
                    <input type="checkbox" name="remember" style="width:15px;height:15px;border-radius:4px;accent-color:#0A4D8C;cursor:pointer;">
                    Remember me
                </label>
                <a href="#" class="forgot-link">Forgot password?</a>
            </div>

            <!-- Error -->
            <% if (error) { %>
            <div class="error-msg">
                <iconify-icon icon="solar:danger-circle-bold" width="16"></iconify-icon>
                <%= error %>
            </div>
            <% } %>

            <!-- Submit -->
            <button type="submit" id="loginButton" class="login-btn">
                <span id="buttonText">Login to Dashboard</span>
                <span id="buttonSpinner" class="hidden" style="display:none;">
                    <svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" stroke-opacity=".3"/>
                        <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                    </svg>
                </span>
                <iconify-icon id="buttonIcon" icon="solar:arrow-right-linear" width="16"></iconify-icon>
            </button>
        </form>

        <!-- Demo pill -->
        <div style="text-align:center;margin-top:20px;">
            <button type="button" class="demo-pill" id="demoPill">
                <iconify-icon icon="solar:key-bold" width="13"></iconify-icon>
                Demo: <strong>admin</strong> / <strong>admin123</strong>
            </button>
        </div>
    </div>

    <script>
        (function () {
            'use strict';
            const loginForm    = document.getElementById('loginForm');
            const loginButton  = document.getElementById('loginButton');
            const buttonText   = document.getElementById('buttonText');
            const buttonSpinner= document.getElementById('buttonSpinner');
            const buttonIcon   = document.getElementById('buttonIcon');
            let isSubmitting   = false;

            function setLoading(v) {
                if (v) {
                    loginButton.disabled       = true;
                    buttonText.style.display   = 'none';
                    buttonSpinner.style.display= 'block';
                    buttonIcon.style.display   = 'none';
                } else {
                    loginButton.disabled       = false;
                    buttonText.style.display   = 'inline';
                    buttonSpinner.style.display= 'none';
                    buttonIcon.style.display   = 'inline';
                }
            }

            loginForm.addEventListener('submit', function (e) {
                if (isSubmitting) { e.preventDefault(); return; }
                const u = document.getElementById('username').value.trim();
                const p = document.getElementById('password').value.trim();
                if (!u || !p) { alert('Please enter both username and password'); e.preventDefault(); return; }
                isSubmitting = true;
                setLoading(true);
            });

            loginButton.addEventListener('click', function (e) {
                if (isSubmitting) e.preventDefault();
            });

            window.addEventListener('pageshow', function (e) {
                if (e.persisted) { isSubmitting = false; setLoading(false); }
            });

            document.getElementById('demoPill').addEventListener('click', function () {
                document.getElementById('username').value = 'admin';
                document.getElementById('password').value = 'admin123';
            });
        })();
    </script>
</body>
</html>