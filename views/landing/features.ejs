<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Features - AquaRoute Maritime</title>
    <meta name="description" content="Explore the full feature set of AquaRoute — real-time ferry tracking, port management, cargo logistics and more.">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        body { font-family:'Inter',sans-serif;background:#EEF2F7;color:#263238;-webkit-font-smoothing:antialiased; }
        h1,h2,h3,h4 { font-family:'Plus Jakarta Sans',sans-serif;letter-spacing:-0.02em; }

        .glass-nav {
            background:rgba(255,255,255,0.88);
            backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
            border-bottom:1px solid #CFD8DC;
        }

        .feature-row {
            background:#fff;
            border:1.5px solid #CFD8DC;
            border-radius:20px;
            padding:40px;
            display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;
            box-shadow:0 2px 8px rgba(0,51,102,0.05);
            transition:box-shadow 0.2s;
        }
        .feature-row:hover { box-shadow:0 8px 24px rgba(0,51,102,0.10); }

        @media(max-width:768px){
            .feature-row { grid-template-columns:1fr; }
            .feature-row.reverse-mobile { direction:ltr; }
        }

        .feature-icon-lg {
            width:64px;height:64px;border-radius:18px;
            display:flex;align-items:center;justify-content:center;
            margin-bottom:24px;
        }

        .stat-chip {
            display:inline-flex;align-items:center;gap:6px;
            padding:6px 14px;border-radius:9999px;
            font-size:12px;font-weight:600;
        }

        /* Slide-up animation */
        .fade-in { animation:fadeIn 0.4s ease-out forwards; }
        @keyframes fadeIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
    </style>
</head>
<body>

    <!-- Navbar -->
    <header class="glass-nav fixed top-0 left-0 right-0 z-50 h-[68px] flex items-center px-8 justify-between">
        <a href="/" class="flex items-center gap-3 no-underline">
            <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#0A4D8C,#00ACC1);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(10,77,140,0.25);">
                <iconify-icon icon="solar:wheel-angle-bold" width="18" style="color:#fff;"></iconify-icon>
            </div>
            <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:17px;font-weight:700;color:#0A4D8C;letter-spacing:-0.02em;">AquaRoute</span>
        </a>
        <div class="flex items-center gap-3">
            <a href="/" class="text-sm font-medium text-slate-500 hover:text-primary transition-colors px-4 py-2 rounded-full hover:bg-blue-50 no-underline" style="color:#546E7A;">← Back to Home</a>
            <a href="/login" class="flex items-center gap-2 text-sm font-semibold border rounded-full px-4 py-2 no-underline transition-all" style="color:#0A4D8C;border-color:#CFD8DC;"
               onmouseover="this.style.borderColor='#0A4D8C';" onmouseout="this.style.borderColor='#CFD8DC';">
                <iconify-icon icon="solar:user-circle-bold" width="15"></iconify-icon>
                Admin Login
            </a>
        </div>
    </header>

    <!-- Hero strip -->
    <section style="background:linear-gradient(160deg,#003366 0%,#0A4D8C 60%,#0077B6 100%);padding:120px 32px 80px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:24px 24px;"></div>
        <div style="position:relative;z-index:1;">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider mb-6"
                 style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9);">
                <iconify-icon icon="solar:star-shine-bold-duotone" width="12"></iconify-icon>
                Platform Capabilities
            </div>
            <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;color:#fff;margin-bottom:16px;font-family:'Plus Jakarta Sans',sans-serif;">
                Everything You Need for<br>Maritime Operations
            </h1>
            <p style="font-size:16px;color:rgba(255,255,255,0.65);max-width:560px;margin:0 auto;">
                AquaRoute bundles real-time tracking, weather intelligence, cargo management, and more into one unified admin platform.
            </p>
        </div>
    </section>

    <!-- Feature Rows -->
    <section style="max-width:1100px;margin:0 auto;padding:64px 32px;display:flex;flex-direction:column;gap:28px;">

        <!-- 1: Real-Time Tracking -->
        <div class="feature-row fade-in">
            <div>
                <div class="feature-icon-lg" style="background:#E3F2FD;">
                    <iconify-icon icon="solar:map-point-wave-bold-duotone" width="30" style="color:#0A4D8C;"></iconify-icon>
                </div>
                <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full text-xs font-semibold" style="background:#E3F2FD;color:#0A4D8C;">Fleet Tracking</div>
                <h2 style="font-size:22px;font-weight:700;color:#263238;margin-bottom:12px;">Real-Time Vessel Tracking</h2>
                <p style="font-size:14px;color:#546E7A;line-height:1.7;margin-bottom:20px;">
                    Monitor every ferry live on the map. Vessel GPS coordinates update in real-time via Firebase Firestore, giving the admin panel and the mobile app always-fresh data.
                </p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <span class="stat-chip" style="background:#E3F2FD;color:#0A4D8C;">Live GPS</span>
                    <span class="stat-chip" style="background:#E8F5E9;color:#2E7D32;">&lt;30s updates</span>
                    <span class="stat-chip" style="background:#B2EBF2;color:#006064;">Real-time sync</span>
                </div>
            </div>
            <div style="background:linear-gradient(135deg,#EEF2F7,#DDEEFF);border-radius:16px;height:220px;display:flex;align-items:center;justify-content:center;">
                <iconify-icon icon="solar:map-bold-duotone" width="100" style="color:#0A4D8C;opacity:0.25;"></iconify-icon>
            </div>
        </div>

        <!-- 2: Weather Integration -->
        <div class="feature-row fade-in">
            <div style="background:linear-gradient(135deg,#EEF2F7,#B2EBF2);border-radius:16px;height:220px;display:flex;align-items:center;justify-content:center;order:-1;">
                <iconify-icon icon="solar:cloud-sun-2-bold-duotone" width="100" style="color:#00ACC1;opacity:0.35;"></iconify-icon>
            </div>
            <div>
                <div class="feature-icon-lg" style="background:#B2EBF2;">
                    <iconify-icon icon="solar:cloud-sun-2-bold-duotone" width="30" style="color:#00ACC1;"></iconify-icon>
                </div>
                <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full text-xs font-semibold" style="background:#B2EBF2;color:#006064;">Weather</div>
                <h2 style="font-size:22px;font-weight:700;color:#263238;margin-bottom:12px;">Smart Weather Integration</h2>
                <p style="font-size:14px;color:#546E7A;line-height:1.7;margin-bottom:20px;">
                    Live weather at each ferry's GPS coordinates and at every registered port. A 15-minute Firestore cache avoids redundant API calls and controls costs.
                </p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <span class="stat-chip" style="background:#B2EBF2;color:#006064;">Coordinate-based</span>
                    <span class="stat-chip" style="background:#E3F2FD;color:#0A4D8C;">15-min cache</span>
                    <span class="stat-chip" style="background:#E8F5E9;color:#2E7D32;">Cost optimized</span>
                </div>
            </div>
        </div>

        <!-- 3: Cargo Tracking -->
        <div class="feature-row fade-in">
            <div>
                <div class="feature-icon-lg" style="background:#E8F5E9;">
                    <iconify-icon icon="solar:box-bold-duotone" width="30" style="color:#4CAF50;"></iconify-icon>
                </div>
                <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full text-xs font-semibold" style="background:#E8F5E9;color:#2E7D32;">Cargo</div>
                <h2 style="font-size:22px;font-weight:700;color:#263238;margin-bottom:12px;">End-to-End Cargo Tracking</h2>
                <p style="font-size:14px;color:#546E7A;line-height:1.7;margin-bottom:20px;">
                    Track cargo through its full lifecycle — Pending → Processing → In Transit → Delivered. Cargo is linked to its carrying ferry so users see the ferry's live weather too.
                </p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <span class="stat-chip" style="background:#E8F5E9;color:#2E7D32;">Linked to Ferry</span>
                    <span class="stat-chip" style="background:#FFF3E0;color:#E65100;">Status tracking</span>
                    <span class="stat-chip" style="background:#E3F2FD;color:#0A4D8C;">Weather relay</span>
                </div>
            </div>
            <div style="background:linear-gradient(135deg,#EEF2F7,#E8F5E9);border-radius:16px;height:220px;display:flex;align-items:center;justify-content:center;">
                <iconify-icon icon="solar:box-bold-duotone" width="100" style="color:#4CAF50;opacity:0.25;"></iconify-icon>
            </div>
        </div>

        <!-- 4: Port Management -->
        <div class="feature-row fade-in">
            <div style="background:linear-gradient(135deg,#EEF2F7,#FFEBEE);border-radius:16px;height:220px;display:flex;align-items:center;justify-content:center;order:-1;">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="100" style="color:#D11717;opacity:0.25;"></iconify-icon>
            </div>
            <div>
                <div class="feature-icon-lg" style="background:#FFEBEE;">
                    <iconify-icon icon="solar:anchor-circle-bold-duotone" width="30" style="color:#D11717;"></iconify-icon>
                </div>
                <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full text-xs font-semibold" style="background:#FFEBEE;color:#B71C1C;">Ports</div>
                <h2 style="font-size:22px;font-weight:700;color:#263238;margin-bottom:12px;">Port Status Management</h2>
                <p style="font-size:14px;color:#546E7A;line-height:1.7;margin-bottom:20px;">
                    Update port statuses — Open, Limited, or Closed — from the web admin. Changes sync to the Android app instantly and nearby ports are surfaced using GPS within 5 km.
                </p>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <span class="stat-chip" style="background:#E8F5E9;color:#2E7D32;">Open</span>
                    <span class="stat-chip" style="background:#FFF3E0;color:#E65100;">Limited</span>
                    <span class="stat-chip" style="background:#FFEBEE;color:#B71C1C;">Closed</span>
                    <span class="stat-chip" style="background:#E3F2FD;color:#0A4D8C;">5km GPS radius</span>
                </div>
            </div>
        </div>

    </section>

    <!-- CTA -->
    <section style="background:linear-gradient(135deg,#003366 0%,#0A4D8C 100%);padding:72px 32px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:24px 24px;"></div>
        <div style="position:relative;z-index:1;">
            <h2 style="font-size:clamp(1.75rem,4vw,2.25rem);font-weight:800;color:#fff;margin-bottom:12px;font-family:'Plus Jakarta Sans',sans-serif;">
                Ready to get started?
            </h2>
            <p style="color:rgba(255,255,255,0.65);font-size:15px;max-width:480px;margin:0 auto 32px;">
                Access the admin panel now and take full control of your maritime fleet.
            </p>
            <a href="/login" style="
                display:inline-flex;align-items:center;gap:8px;
                padding:14px 36px;border-radius:16px;
                background:#fff;color:#0A4D8C;
                font-weight:700;font-size:15px;font-family:'Plus Jakarta Sans',sans-serif;
                text-decoration:none;
                box-shadow:0 8px 24px rgba(255,255,255,0.15);
                transition:all 0.2s;
            "
            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 30px rgba(255,255,255,0.22)';"
            onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 24px rgba(255,255,255,0.15)';">
                <iconify-icon icon="solar:login-2-bold" width="18"></iconify-icon>
                Access Admin Panel
            </a>
        </div>
    </section>

    <!-- Footer -->
    <footer style="background:#001F42;padding:36px 32px;">
        <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:16px;">
            <div style="display:flex;align-items:center;gap:8px;">
                <div style="width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;">
                    <iconify-icon icon="solar:wheel-angle-bold" width="14" style="color:#00ACC1;"></iconify-icon>
                </div>
                <span style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;color:#fff;font-size:14px;">AquaRoute</span>
            </div>
            <span style="font-size:12px;color:#546E7A;">© 2026 AquaRoute Inc. All rights reserved.</span>
            <div style="display:flex;gap:20px;">
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:facebook" width="16"></iconify-icon></a>
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:x-twitter" width="16"></iconify-icon></a>
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:linkedin" width="16"></iconify-icon></a>
            </div>
        </div>
    </footer>

</body>
</html>
