<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom Config & Styles -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Quicksand', 'sans-serif'],
                        display: ['Rubik', 'sans-serif'],
                    },
                    colors: {
                        primary: '#87A2FF',
                        secondary: '#C4D7FF',
                        accent: '#62AE7D',
                        surface: '#FFD7C4',
                        card: '#FFF4B5',
                        star: '#BD77FF',
                        square: '#FEC1A0',
                        circle: '#99123D',
                        textfield: '#FFF4B5',
                        label: '#65676B',
                    }
                }
            }
        }
    </script>

    <style>
        /* Base & Reset */
        body { 
            font-family: 'Quicksand', sans-serif; 
            background-color: #FFD7C4;
            -webkit-font-smoothing: antialiased;
            color: #2D2F31;
        }
        
        h1, h2, h3, h4, h5, h6 { 
            font-family: 'Rubik', sans-serif; 
            letter-spacing: -0.02em; 
            font-weight: 600;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #FEC1A0; }
        ::-webkit-scrollbar-thumb { background: #BD77FF; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #99123D; }

        /* Animations */
        .fade-in { animation: fadeIn 0.4s ease-out forwards; }
        .slide-up { animation: slideUp 0.5s ease-out forwards; }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Glassmorphism */
        .glass {
            background: rgba(255, 244, 181, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(135, 162, 255, 0.3);
        }

        /* Wave Decoration */
        .wave-bg {
            background: linear-gradient(180deg, rgba(196,215,255,1) 0%, rgba(255,215,196,0.5) 100%);
        }

        /* Status Badge Animations */
        .status-dot { animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(189, 119, 255, 0.5); }
            70% { box-shadow: 0 0 0 6px rgba(189, 119, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(189, 119, 255, 0); }
        }

        /* Mock Input Style */
        .mock-input {
            background-color: #FFF4B5;
            border: 2px solid #87A2FF;
            border-radius: 20px;
            padding: 0.5rem 1rem;
            font-weight: 500;
            color: #2D2F31;
        }

        /* Custom hover effects */
        .feature-card {
            background-color: #FFF4B5;
            border: 1px solid #87A2FF;
            border-radius: 1.5rem;
            padding: 2rem;
            transition: all 0.3s ease;
        }
        
        .feature-card:hover {
            background-color: #FEC1A0;
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(135, 162, 255, 0.3);
        }

        .icon-wrapper {
            width: 3rem;
            height: 3rem;
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            transition: transform 0.3s ease;
        }

        .feature-card:hover .icon-wrapper {
            transform: scale(1.1);
        }

        .cta-button {
            background-color: #FFF4B5;
            color: #99123D;
            padding: 1rem 2rem;
            border-radius: 1rem;
            font-weight: 700;
            transition: all 0.3s ease;
            display: inline-block;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .cta-button:hover {
            background-color: #FEC1A0;
        }

        .admin-button {
            background-color: #FFF4B5;
            border: 1px solid #87A2FF;
            color: #65676B;
            padding: 0.625rem 1.25rem;
            border-radius: 9999px;
            font-weight: 500;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }

        .admin-button:hover {
            border-color: #87A2FF;
            background-color: #FEC1A0;
        }

        .admin-button:hover iconify-icon {
            color: #99123D;
        }

        .get-app-button {
            background-color: #BD77FF;
            color: white;
            padding: 0.625rem 1.25rem;
            border-radius: 9999px;
            font-weight: 500;
            font-size: 0.875rem;
            box-shadow: 0 10px 15px -3px rgba(189, 119, 255, 0.4);
            transition: all 0.3s ease;
        }

        .get-app-button:hover {
            background-color: #99123D;
        }
    </style>
</head>
<body class="overflow-x-hidden">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 glass transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg" style="background-color: #87A2FF; box-shadow: 0 10px 15px -3px rgba(135,162,255,0.3);">
                    <img src="/aquaRoute_logo.svg" alt="AquaRoute Logo" class="w-6 h-6 brightness-0 invert">
                </div>
                <span class="font-display font-bold text-xl tracking-tight" style="color: #99123D;">AquaRoute</span>
            </div>
            <div class="flex items-center gap-4">
                <a href="/login" class="hidden md:flex admin-button">
                    <iconify-icon icon="solar:user-circle-bold" style="color: #99123D;"></iconify-icon>
                    Admin Login
                </a>
                <button class="get-app-button">
                    Get App
                </button>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-6 wave-bg relative overflow-hidden">
        <!-- Decorative Elements -->
        <div class="absolute top-20 right-[-100px] w-96 h-96 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="background-color: #BD77FF;"></div>
        <div class="absolute bottom-20 left-[-100px] w-96 h-96 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="background-color: #FEC1A0; animation-delay: 2s;"></div>

        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
            <div class="space-y-8 slide-up">
                <!-- badge -->
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider" style="background-color: #FFF4B5; border: 1px solid #87A2FF; color: #99123D;">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background-color: #BD77FF;"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2" style="background-color: #62AE7D;"></span>
                    </span>
                    Live System v2.0
                </div>
                <h1 class="text-5xl md:text-6xl font-display font-bold leading-[1.1] tracking-tight" style="color: #2D2F31;">
                    Streamline Ferry <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r" style="background-image: linear-gradient(to right, #99123D, #BD77FF);">Operations</span>
                </h1>
                <p class="text-lg max-w-lg leading-relaxed" style="color: #4A4D52;">
                    Monitor vessel locations, update statuses, and manage port information from one centralized dashboard. Real-time visibility for safer seas.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 pt-2">
                    <a href="/login" class="px-8 py-4 rounded-2xl text-white font-semibold transition-all shadow-xl flex items-center justify-center gap-2" style="background-color: #87A2FF; box-shadow: 0 20px 25px -5px rgba(135,162,255,0.4);">
                        <iconify-icon icon="solar:login-2-bold"></iconify-icon>
                        Admin Access
                    </a>
                    <button class="px-8 py-4 rounded-2xl font-semibold transition-all flex items-center justify-center gap-2" style="background-color: #FFF4B5; border: 2px solid #87A2FF; color: #65676B;">
                        <iconify-icon icon="solar:play-circle-bold-duotone" style="color: #99123D;"></iconify-icon>
                        View Demo
                    </button>
                </div>
            </div>

            <!-- Abstract Map Graphic -->
            <div class="relative h-[500px] rounded-[40px] shadow-2xl border p-4 slide-up" style="animation-delay: 0.2s; background-color: #FFF4B5; border-color: #87A2FF;">
                <div class="absolute inset-4 rounded-[32px] overflow-hidden" style="background-color: #FEC1A0;">
                    <!-- Mock Map Design -->
                    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(#BD77FF 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <!-- Land Mass -->
                    <div class="absolute top-0 right-0 w-2/3 h-full rounded-l-[100px] border-l" style="background-color: #C4D7FF; border-color: #87A2FF;"></div>
                    
                    <!-- Route Lines -->
                    <svg class="absolute inset-0 w-full h-full pointer-events-none">
                        <path d="M 100 300 Q 250 250 400 150" fill="none" stroke="#62AE7D" stroke-width="3" stroke-dasharray="8 8" class="animate-pulse"></path>
                        <path d="M 80 200 Q 200 350 380 280" fill="none" stroke="#99123D" stroke-width="2" stroke-dasharray="6 6" class="animate-pulse" style="animation-delay: 1s;"></path>
                    </svg>

                    <!-- Floating Cards -->
                    <div class="absolute top-1/4 left-1/4 p-3 rounded-xl shadow-lg border flex items-center gap-3 animate-bounce" style="animation-duration: 3s; background-color: #FFF4B5; border-color: #87A2FF;">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: #62AE7D; color: white;">
                            <iconify-icon icon="solar:ship-bold" width="20"></iconify-icon>
                        </div>
                        <div>
                            <div class="text-xs font-bold" style="color: #2D2F31;">FastCat 01</div>
                            <div class="text-[10px] font-medium" style="color: #62AE7D;">On Time • 15kts</div>
                        </div>
                    </div>

                    <div class="absolute bottom-1/3 right-1/4 p-3 rounded-xl shadow-lg border flex items-center gap-3 animate-bounce" style="animation-duration: 4s; background-color: #FFF4B5; border-color: #87A2FF;">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: #BD77FF; color: white;">
                            <iconify-icon icon="solar:ship-bold" width="20"></iconify-icon>
                        </div>
                        <div>
                            <div class="text-xs font-bold" style="color: #2D2F31;">OceanJet 8</div>
                            <div class="text-[10px] font-medium" style="color: #BD77FF;">Delayed (+15m)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section class="py-24" style="background-color: #C4D7FF;">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-display font-bold mb-4" style="color: #2D2F31;">Powerful Management Tools</h2>
                <p class="max-w-2xl mx-auto" style="color: #65676B;">Everything you need to manage your maritime logistics efficiently.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Feature 1 -->
                <div class="feature-card">
                    <div class="icon-wrapper" style="background-color: #BD77FF; color: white;">
                        <iconify-icon icon="solar:map-point-wave-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: #2D2F31;">Real-Time Tracking</h3>
                    <p class="text-sm leading-relaxed" style="color: #65676B;">Track all vessels live on the map with update intervals of less than 30 seconds.</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card">
                    <div class="icon-wrapper" style="background-color: #62AE7D; color: white;">
                        <iconify-icon icon="solar:clock-circle-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: #2D2F31;">Dynamic ETA</h3>
                    <p class="text-sm leading-relaxed" style="color: #65676B;">System automatically calculates arrival times based on current speed and weather.</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card">
                    <div class="icon-wrapper" style="background-color: #99123D; color: white;">
                        <iconify-icon icon="solar:bell-bing-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold mb-2" style="color: #2D2F31;">Instant Advisories</h3>
                    <p class="text-sm leading-relaxed" style="color: #65676B;">Push notifications to passengers regarding cancellations or port changes.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6">
        <div class="max-w-5xl mx-auto rounded-[40px] relative overflow-hidden text-center py-20 px-8" style="background-color: #99123D;">
            <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(45deg, #BD77FF 25%, transparent 25%, transparent 50%, #FEC1A0 50%, #FEC1A0 75%, transparent 75%, transparent); background-size: 40px 40px;"></div>
            
            <div class="relative z-10">
                <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">Ready to transform your operations?</h2>
                <p class="mb-10 max-w-xl mx-auto" style="color: #FFD7C4;">Join the leading ferry operators using AquaRoute to improve efficiency and passenger satisfaction.</p>
                <a href="/login" class="cta-button">
                    Access Admin Panel
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-6" style="background-color: #65676B; color: #FFD7C4;">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2">
                <iconify-icon icon="solar:wheel-angle-bold" style="color: #BD77FF;"></iconify-icon>
                <span class="font-bold tracking-tight" style="color: #FFF4B5;">AquaRoute</span>
            </div>
            <div class="text-sm font-medium" style="color: #C4D7FF;">
                © 2026 AquaRoute Inc. All rights reserved.
            </div>
            <div class="flex gap-6">
                <a href="#" class="transition-colors hover:text-white" style="color: #FEC1A0;"><iconify-icon icon="brands:facebook" width="20"></iconify-icon></a>
                <a href="#" class="transition-colors hover:text-white" style="color: #62AE7D;"><iconify-icon icon="brands:twitter" width="20"></iconify-icon></a>
                <a href="#" class="transition-colors hover:text-white" style="color: #BD77FF;"><iconify-icon icon="brands:linkedin" width="20"></iconify-icon></a>
            </div>
        </div>
    </footer>

</body>
</html>