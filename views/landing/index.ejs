<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>
    <meta name="description" content="AquaRoute Maritime — Real-time ferry tracking, port management, and cargo logistics for the Philippines.">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary:    '#0A4D8C',
                        'primary-dark': '#073B6B',
                        accent:     '#00ACC1',
                        'bg-light': '#EEF2F7',
                        success:    '#4CAF50',
                        warning:    '#FF9800',
                    },
                    fontFamily: {
                        sans:    ['Inter', 'sans-serif'],
                        display: ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #EEF2F7; color: #263238; -webkit-font-smoothing: antialiased; }
        h1,h2,h3,h4 { font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: -0.02em; }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #90A4AE; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #0A4D8C; }

        .fade-in  { animation: fadeIn  0.4s ease-out forwards; }
        .slide-up { animation: slideUp 0.5s ease-out forwards; }
        @keyframes fadeIn  { from{opacity:0} to{opacity:1} }
        @keyframes slideUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

        /* Glassmorphism nav */
        .glass-nav {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid #CFD8DC;
        }

        /* Hero */
        .hero-bg {
            background: linear-gradient(160deg, #003366 0%, #0A4D8C 50%, #0077B6 100%);
        }

        /* Feature cards */
        .feature-card {
            background: #fff;
            border: 1.5px solid #CFD8DC;
            border-radius: 20px;
            padding: 32px;
            transition: all 0.25s ease;
            box-shadow: 0 2px 8px rgba(0,51,102,0.06);
        }
        .feature-card:hover {
            border-color: #0A4D8C;
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,51,102,0.12);
        }
        .feature-card:hover .feat-icon { transform: scale(1.1); }
        .feat-icon { width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;transition:transform 0.25s; }

        /* CTA section */
        .cta-section { background: linear-gradient(135deg, #003366 0%, #0A4D8C 100%); }

        /* Pulse dot */
        .live-dot { animation: pulse 2s infinite; }
        @keyframes pulse {
            0%  { box-shadow: 0 0 0 0 rgba(76,175,80,0.5); }
            70% { box-shadow: 0 0 0 8px rgba(76,175,80,0); }
            100%{ box-shadow: 0 0 0 0 rgba(76,175,80,0); }
        }
    </style>
</head>
<body class="overflow-x-hidden">

    <!-- ═══ NAVBAR ═══════════════════════════════════════════ -->
    <header class="glass-nav fixed top-0 left-0 right-0 z-50 h-[68px] flex items-center px-8 justify-between">
        <a href="/" class="flex items-center gap-3 no-underline">
            <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#0A4D8C,#00ACC1);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(10,77,140,0.25);">
            <img src="aquaRoute_logo.svg" alt="AquaRoute Logo"
                 style="width:20px;height:20px;object-fit:contain;filter:brightness(0) invert(1);">
            </div>
            <span class="font-display font-bold text-[17px] text-primary tracking-tight">AquaRoute</span>
        </a>
        <div class="flex items-center gap-3">
            <a href="/features" class="hidden md:block text-sm font-medium text-slate-500 hover:text-primary transition-colors px-4 py-2 rounded-full hover:bg-blue-50">Features</a>
            <a href="/login" class="hidden md:flex items-center gap-2 text-sm font-semibold text-slate-600 border border-slate-200 rounded-full px-4 py-2 hover:border-primary hover:text-primary transition-all">
                <iconify-icon icon="solar:user-circle-bold" width="15"></iconify-icon>
                Admin Login
            </a>
            <button class="text-sm font-semibold text-white rounded-full px-4 py-2 border-0 cursor-pointer transition-all" style="background:linear-gradient(135deg,#0A4D8C,#00ACC1);box-shadow:0 4px 12px rgba(10,77,140,0.28);">
                Get App
            </button>
        </div>
    </header>

    <!-- ═══ HERO ══════════════════════════════════════════════ -->
    <section class="hero-bg min-h-screen flex items-center pt-20 pb-16 px-6 relative overflow-hidden">
        <!-- Decorative orbs -->
        <div class="absolute top-[-80px] right-[-100px] w-[500px] h-[500px] rounded-full" style="background:rgba(0,172,193,0.12);filter:blur(80px);pointer-events:none;"></div>
        <div class="absolute bottom-[-80px] left-[-100px] w-[400px] h-[400px] rounded-full" style="background:rgba(76,175,80,0.08);filter:blur(80px);pointer-events:none;"></div>

        <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-14 items-center relative z-10">

            <!-- Text block -->
            <div class="slide-up space-y-8">
                <!-- Live badge -->
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider"
                     style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9);">
                    <span class="relative flex w-2 h-2">
                        <span class="live-dot absolute inline-flex w-full h-full rounded-full" style="background:#4CAF50;"></span>
                        <span class="relative inline-flex w-2 h-2 rounded-full" style="background:#4CAF50;"></span>
                    </span>
                    Live System v2.0
                </div>

                <h1 class="font-display font-bold text-white" style="font-size:clamp(2.5rem,5vw,3.75rem);line-height:1.1;">
                    Streamline Ferry<br>
                    <span style="background:linear-gradient(90deg,#00ACC1,#67E8F9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Operations</span>
                </h1>

                <p class="text-lg max-w-lg leading-relaxed" style="color:rgba(255,255,255,0.72);">
                    Monitor vessel locations, update statuses, and manage port information from one centralized dashboard. Real-time visibility for safer seas.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/login" class="flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-white font-semibold no-underline"
                       style="background:#fff;color:#0A4D8C;box-shadow:0 8px 24px rgba(255,255,255,0.20);transition:all 0.2s;"
                       onmouseover="this.style.boxShadow='0 12px 30px rgba(255,255,255,0.30)';this.style.transform='translateY(-2px)';"
                       onmouseout="this.style.boxShadow='0 8px 24px rgba(255,255,255,0.20)';this.style.transform='translateY(0)';">
                        <iconify-icon icon="solar:login-2-bold" width="18"></iconify-icon>
                        Admin Access
                    </a>
                    <a href="/features" class="flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-semibold no-underline"
                       style="background:rgba(255,255,255,0.10);color:#fff;border:1.5px solid rgba(255,255,255,0.22);transition:all 0.2s;"
                       onmouseover="this.style.background='rgba(255,255,255,0.18)';" onmouseout="this.style.background='rgba(255,255,255,0.10)';">
                        <iconify-icon icon="solar:star-shine-bold-duotone" width="18"></iconify-icon>
                        See Features
                    </a>
                </div>

                <!-- Stats ticker -->
                <div class="flex gap-8 pt-2">
                    <div>
                        <div class="font-display font-bold text-2xl text-white">24/7</div>
                        <div class="text-xs mt-0.5" style="color:rgba(255,255,255,0.5);">Monitoring</div>
                    </div>
                    <div style="width:1px;background:rgba(255,255,255,0.12);"></div>
                    <div>
                        <div class="font-display font-bold text-2xl text-white">Real-time</div>
                        <div class="text-xs mt-0.5" style="color:rgba(255,255,255,0.5);">Weather Data</div>
                    </div>
                    <div style="width:1px;background:rgba(255,255,255,0.12);"></div>
                    <div>
                        <div class="font-display font-bold text-2xl text-white">100%</div>
                        <div class="text-xs mt-0.5" style="color:rgba(255,255,255,0.5);">Cloud-Backed</div>
                    </div>
                </div>
            </div>

            <!-- Dashboard preview card -->
            <div class="slide-up" style="animation-delay:0.15s;">
                <div style="background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.12);border-radius:28px;padding:20px;">
                    <!-- Mini dashboard UI mockup -->
                    <div style="background:rgba(255,255,255,0.06);border-radius:16px;padding:16px;margin-bottom:12px;">
                        <div style="font-size:10px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Live Fleet Status</div>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
                            <div style="background:rgba(76,175,80,0.15);border:1px solid rgba(76,175,80,0.3);border-radius:10px;padding:12px;text-align:center;">
                                <div style="font-size:22px;font-weight:700;color:#4CAF50;">8</div>
                                <div style="font-size:10px;color:rgba(255,255,255,0.5);margin-top:2px;">Active</div>
                            </div>
                            <div style="background:rgba(255,152,0,0.15);border:1px solid rgba(255,152,0,0.3);border-radius:10px;padding:12px;text-align:center;">
                                <div style="font-size:22px;font-weight:700;color:#FF9800;">2</div>
                                <div style="font-size:10px;color:rgba(255,255,255,0.5);margin-top:2px;">Delayed</div>
                            </div>
                            <div style="background:rgba(0,172,193,0.15);border:1px solid rgba(0,172,193,0.3);border-radius:10px;padding:12px;text-align:center;">
                                <div style="font-size:22px;font-weight:700;color:#00ACC1;">3</div>
                                <div style="font-size:10px;color:rgba(255,255,255,0.5);margin-top:2px;">Docked</div>
                            </div>
                        </div>
                    </div>

                    <!-- Ferry cards -->
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:12px;padding:12px;display:flex;align-items:center;gap:10px;">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(76,175,80,0.20);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <iconify-icon icon="solar:ship-bold" width="18" style="color:#4CAF50;"></iconify-icon>
                            </div>
                            <div style="flex:1;">
                                <div style="font-size:13px;font-weight:600;color:#fff;">FastCat 01</div>
                                <div style="font-size:11px;color:rgba(255,255,255,0.45);margin-top:1px;">Manila → Batangas · 15 kts</div>
                            </div>
                            <span style="font-size:10px;font-weight:600;color:#4CAF50;background:rgba(76,175,80,0.15);padding:3px 8px;border-radius:9999px;">On Time</span>
                        </div>
                        <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:12px;padding:12px;display:flex;align-items:center;gap:10px;">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,152,0,0.20);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <iconify-icon icon="solar:ship-bold" width="18" style="color:#FF9800;"></iconify-icon>
                            </div>
                            <div style="flex:1;">
                                <div style="font-size:13px;font-weight:600;color:#fff;">OceanJet 8</div>
                                <div style="font-size:11px;color:rgba(255,255,255,0.45);margin-top:1px;">Cebu → Ormoc · 12 kts</div>
                            </div>
                            <span style="font-size:10px;font-weight:600;color:#FF9800;background:rgba(255,152,0,0.15);padding:3px 8px;border-radius:9999px;">Delayed</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- ═══ FEATURES GRID ═════════════════════════════════════ -->
    <section class="py-24 px-6" style="background:#EEF2F7;">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider mb-4"
                     style="background:#E3F2FD;color:#0A4D8C;border:1px solid #BBDEFB;">
                    <iconify-icon icon="solar:star-shine-bold-duotone" width="12"></iconify-icon>
                    Platform Features
                </div>
                <h2 class="font-display font-bold text-3xl mb-4" style="color:#263238;">Powerful Maritime Management Tools</h2>
                <p class="max-w-2xl mx-auto text-slate-500 text-base">Everything you need to manage your ferry operations and cargo logistics from one unified dashboard.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Feature 1 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#E3F2FD;">
                        <iconify-icon icon="solar:map-point-wave-bold-duotone" width="26" style="color:#0A4D8C;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Real-Time Tracking</h3>
                    <p class="text-sm leading-relaxed text-slate-500">Track all vessels live on the map with update intervals under 30 seconds via Firebase Firestore.</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#E8F5E9;">
                        <iconify-icon icon="solar:clock-circle-bold-duotone" width="26" style="color:#4CAF50;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Dynamic ETA</h3>
                    <p class="text-sm leading-relaxed text-slate-500">Arrival times calculated automatically based on current speed and live weather conditions.</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#FFF3E0;">
                        <iconify-icon icon="solar:bell-bing-bold-duotone" width="26" style="color:#FF9800;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Instant Advisories</h3>
                    <p class="text-sm leading-relaxed text-slate-500">Push notifications to passengers for cancellations, delays, and port changes in real time.</p>
                </div>

                <!-- Feature 4 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#B2EBF2;">
                        <iconify-icon icon="solar:cloud-sun-2-bold-duotone" width="26" style="color:#00ACC1;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Weather Integration</h3>
                    <p class="text-sm leading-relaxed text-slate-500">Live weather data pulled per ferry coordinates and port locations with a 15-minute smart cache.</p>
                </div>

                <!-- Feature 5 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#E8F5E9;">
                        <iconify-icon icon="solar:box-bold-duotone" width="26" style="color:#4CAF50;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Cargo Tracking</h3>
                    <p class="text-sm leading-relaxed text-slate-500">End-to-end cargo visibility linked to ferry routes and real-time ferry positions.</p>
                </div>

                <!-- Feature 6 -->
                <div class="feature-card">
                    <div class="feat-icon" style="background:#FFEBEE;">
                        <iconify-icon icon="solar:anchor-circle-bold-duotone" width="26" style="color:#D11717;"></iconify-icon>
                    </div>
                    <h3 class="font-display font-bold text-lg mb-2" style="color:#263238;">Port Management</h3>
                    <p class="text-sm leading-relaxed text-slate-500">Update port statuses (Open / Limited / Closed) and broadcast changes to the mobile app instantly.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CTA ═══════════════════════════════════════════════ -->
    <section class="cta-section py-20 px-6 relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:24px 24px;"></div>
        <div class="max-w-3xl mx-auto text-center relative z-10">
            <h2 class="font-display font-bold text-white mb-4" style="font-size:clamp(1.75rem,4vw,2.5rem);">Ready to transform your operations?</h2>
            <p class="mb-10 text-base max-w-xl mx-auto" style="color:rgba(255,255,255,0.65);">
                Join AquaRoute and bring real-time maritime intelligence to your fleet management.
            </p>
            <a href="/login" class="inline-flex items-center gap-2 px-10 py-4 rounded-2xl font-semibold no-underline transition-all"
               style="background:#fff;color:#0A4D8C;box-shadow:0 8px 24px rgba(255,255,255,0.15);"
               onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 30px rgba(255,255,255,0.22)';"
               onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 24px rgba(255,255,255,0.15)';">
                <iconify-icon icon="solar:login-2-bold" width="18"></iconify-icon>
                Access Admin Panel
            </a>
        </div>
    </section>

    <footer style="background:#001F42;padding:40px 32px;">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-5">
            <div class="flex items-center gap-2">
                <div style="width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;">
                    <img src="aquaRoute_logo.svg" alt="AquaRoute Logo" style="width:14px;height:14px;filter:brightness(0) invert(1);">
                </div>
                <span style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;color:#fff;font-size:15px;">AquaRoute</span>
            </div>
            <span style="font-size:12px;color:#546E7A;">© 2026 AquaRoute Inc. All rights reserved.</span>
            <div class="flex gap-5">
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:facebook" width="17"></iconify-icon></a>
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:x-twitter" width="17"></iconify-icon></a>
                <a href="#" style="color:#546E7A;transition:color 0.2s;" onmouseover="this.style.color='#fff';" onmouseout="this.style.color='#546E7A';"><iconify-icon icon="fa6-brands:linkedin" width="17"></iconify-icon></a>
            </div>
        </div>
    </footer>

</body>
</html>