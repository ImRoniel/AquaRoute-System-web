<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom Config & Styles -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Plus Jakarta Sans', 'sans-serif'],
                    },
                    colors: {
                        primary: '#0A4D8C',     // Deep Ocean Blue
                        secondary: '#1E88E5',   // Bright Blue
                        accent: '#00ACC1',      // Teal
                        surface: '#F8FAFC',     // Light Blue Gray
                        card: '#FFFFFF',
                    }
                }
            }
        }
    </script>

    <style>
        /* Base & Reset */
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #F8FAFC;
            -webkit-font-smoothing: antialiased;
        }
        
        h1, h2, h3, h4, h5, h6 { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            letter-spacing: -0.025em; 
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #94A3B8; }

        /* Animations */
        .fade-in { animation: fadeIn 0.4s ease-out forwards; }
        .slide-up { animation: slideUp 0.5s ease-out forwards; }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Glassmorphism utilities */
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* Wave Decoration */
        .wave-bg {
            background: linear-gradient(180deg, rgba(237,247,255,1) 0%, rgba(248,250,252,0) 100%);
        }

        /* Status Badge Animations */
        .status-dot { animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(10, 77, 140, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(10, 77, 140, 0); }
            100% { box-shadow: 0 0 0 0 rgba(10, 77, 140, 0); }
        }
    </style>
</head>
<body class="text-slate-600 overflow-x-hidden">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 glass transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg shadow-blue-900/20">
                    <img src="/aquaRoute_logo.svg" alt="AquaRoute Logo" class="w-6 h-6">
                </div>
                <span class="font-display font-bold text-xl text-primary tracking-tight">AquaRoute</span>
            </div>
            <div class="flex items-center gap-4">
                <a href="/login" class="hidden md:flex items-center gap-2 px-5 py-2.5 rounded-full border border-slate-200 text-slate-600 font-medium hover:border-primary hover:text-primary transition-all text-sm group">
                    <iconify-icon icon="solar:user-circle-bold" class="text-slate-400 group-hover:text-primary transition-colors"></iconify-icon>
                    Admin Login
                </a>
                <button class="px-5 py-2.5 rounded-full bg-primary text-white font-medium hover:bg-blue-800 transition-all text-sm shadow-lg shadow-blue-900/20">
                    Get App
                </button>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-6 wave-bg relative overflow-hidden">
        <!-- Decorative Elements -->
        <div class="absolute top-20 right-[-100px] w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute bottom-20 left-[-100px] w-96 h-96 bg-cyan-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="animation-delay: 2s"></div>

        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
            <div class="space-y-8 slide-up">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-600 text-xs font-semibold uppercase tracking-wider">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
                    </span>
                    Live System v2.0
                </div>
                <h1 class="text-5xl md:text-6xl font-display font-bold text-slate-900 leading-[1.1] tracking-tight">
                    Streamline Ferry <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Operations</span>
                </h1>
                <p class="text-lg text-slate-500 max-w-lg leading-relaxed">
                    Monitor vessel locations, update statuses, and manage port information from one centralized dashboard. Real-time visibility for safer seas.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 pt-2">
                    <a href="/login" class="px-8 py-4 rounded-2xl bg-primary text-white font-semibold hover:bg-blue-800 transition-all shadow-xl shadow-blue-900/20 flex items-center justify-center gap-2">
                        <iconify-icon icon="solar:login-2-bold"></iconify-icon>
                        Admin Access
                    </a>
                    <button class="px-8 py-4 rounded-2xl bg-white border border-slate-200 text-slate-600 font-semibold hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                        <iconify-icon icon="solar:play-circle-bold-duotone" class="text-secondary"></iconify-icon>
                        View Demo
                    </button>
                </div>
            </div>

            <!-- Abstract Map Graphic -->
            <div class="relative h-[500px] bg-white rounded-[40px] shadow-2xl border border-slate-100 p-4 slide-up" style="animation-delay: 0.2s">
                <div class="absolute inset-4 rounded-[32px] overflow-hidden bg-blue-50">
                    <!-- Mock Map Design -->
                    <div class="absolute inset-0 opacity-50" style="background-image: radial-gradient(#CBD5E1 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <!-- Land Mass -->
                    <div class="absolute top-0 right-0 w-2/3 h-full bg-white/80 rounded-l-[100px] border-l border-slate-200"></div>
                    
                    <!-- Route Lines -->
                    <svg class="absolute inset-0 w-full h-full pointer-events-none">
                        <path d="M 100 300 Q 250 250 400 150" fill="none" stroke="#3B82F6" stroke-width="3" stroke-dasharray="8 8" class="animate-pulse"></path>
                    </svg>

                    <!-- Floating Cards -->
                    <div class="absolute top-1/4 left-1/4 bg-white p-3 rounded-xl shadow-lg border border-slate-100 flex items-center gap-3 animate-bounce" style="animation-duration: 3s;">
                        <div class="w-10 h-10 rounded-lg bg-green-100 text-green-600 flex items-center justify-center">
                            <iconify-icon icon="solar:ship-bold" width="20"></iconify-icon>
                        </div>
                        <div>
                            <div class="text-xs font-bold text-slate-800">FastCat 01</div>
                            <div class="text-[10px] font-medium text-green-600">On Time • 15kts</div>
                        </div>
                    </div>

                    <div class="absolute bottom-1/3 right-1/4 bg-white p-3 rounded-xl shadow-lg border border-slate-100 flex items-center gap-3 animate-bounce" style="animation-duration: 4s;">
                        <div class="w-10 h-10 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center">
                            <iconify-icon icon="solar:ship-bold" width="20"></iconify-icon>
                        </div>
                        <div>
                            <div class="text-xs font-bold text-slate-800">OceanJet 8</div>
                            <div class="text-[10px] font-medium text-orange-600">Delayed (+15m)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-display font-bold text-slate-900 mb-4">Powerful Management Tools</h2>
                <p class="text-slate-500 max-w-2xl mx-auto">Everything you need to manage your maritime logistics efficiently.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Feature 1 -->
                <div class="p-8 rounded-3xl bg-slate-50 hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all border border-slate-100 group">
                    <div class="w-12 h-12 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <iconify-icon icon="solar:map-point-wave-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Real-Time Tracking</h3>
                    <p class="text-sm text-slate-500 leading-relaxed">Track all vessels live on the map with update intervals of less than 30 seconds.</p>
                </div>

                <!-- Feature 2 -->
                <div class="p-8 rounded-3xl bg-slate-50 hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all border border-slate-100 group">
                    <div class="w-12 h-12 rounded-2xl bg-orange-100 text-orange-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <iconify-icon icon="solar:clock-circle-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Dynamic ETA</h3>
                    <p class="text-sm text-slate-500 leading-relaxed">System automatically calculates arrival times based on current speed and weather.</p>
                </div>

                <!-- Feature 3 -->
                <div class="p-8 rounded-3xl bg-slate-50 hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all border border-slate-100 group">
                    <div class="w-12 h-12 rounded-2xl bg-teal-100 text-teal-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                        <iconify-icon icon="solar:bell-bing-bold-duotone" width="28"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Instant Advisories</h3>
                    <p class="text-sm text-slate-500 leading-relaxed">Push notifications to passengers regarding cancellations or port changes.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6">
        <div class="max-w-5xl mx-auto rounded-[40px] bg-primary relative overflow-hidden text-center py-20 px-8">
            <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(45deg, #ffffff 25%, transparent 25%, transparent 50%, #ffffff 50%, #ffffff 75%, transparent 75%, transparent); background-size: 40px 40px;"></div>
            
            <div class="relative z-10">
                <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">Ready to transform your operations?</h2>
                <p class="text-blue-100 mb-10 max-w-xl mx-auto">Join the leading ferry operators using AquaRoute to improve efficiency and passenger satisfaction.</p>
                <a href="/login" class="px-8 py-4 rounded-2xl bg-white text-primary font-bold hover:bg-blue-50 transition-all shadow-lg inline-block">
                    Access Admin Panel
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-12 px-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2">
                <iconify-icon icon="solar:wheel-angle-bold" class="text-blue-500"></iconify-icon>
                <span class="font-bold text-white tracking-tight">AquaRoute</span>
            </div>
            <div class="text-sm font-medium">
                © 2026 AquaRoute Inc. All rights reserved.
            </div>
            <div class="flex gap-6">
                <a href="#" class="hover:text-white transition-colors"><iconify-icon icon="brands:facebook" width="20"></iconify-icon></a>
                <a href="#" class="hover:text-white transition-colors"><iconify-icon icon="brands:twitter" width="20"></iconify-icon></a>
                <a href="#" class="hover:text-white transition-colors"><iconify-icon icon="brands:linkedin" width="20"></iconify-icon></a>
            </div>
        </div>
    </footer>

</body>
</html>