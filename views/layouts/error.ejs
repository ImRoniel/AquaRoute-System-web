<!-- views/layouts/error.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Error' %> - AquaRoute</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <!-- Font Awesome as backup -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-[#FFD7C4]">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-lg border-2 border-[#87A2FF] p-8 max-w-lg w-full">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-[#99123D] rounded-full flex items-center justify-center">
                    <iconify-icon icon="solar:danger-circle-bold" width="32" style="color: white;"></iconify-icon>
                </div>
            </div>
            <h1 class="text-2xl font-bold text-center mb-2" style="color: #99123D;">Oops!</h1>
            <p class="text-gray-600 text-center mb-6"><%= error || 'Something went wrong' %></p>
            
            <% if (user) { %>
            <div class="text-center">
                <a href="/admin/dashboard" class="inline-block px-6 py-2 bg-[#87A2FF] text-white rounded-lg hover:bg-[#99123D] transition-colors">
                    Go to Dashboard
                </a>
            </div>
            <% } else { %>
            <div class="text-center">
                <a href="/" class="inline-block px-6 py-2 bg-[#87A2FF] text-white rounded-lg hover:bg-[#99123D] transition-colors">
                    Go to Home
                </a>
            </div>
            <% } %>
        </div>
    </div>
</body>
</html>