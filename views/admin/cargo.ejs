<!-- views/admin/cargo.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute Admin</title>

    <!-- AquaRoute Maritime Theme -->
    <link rel="stylesheet" href="/css/admin-theme.css">

    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* Page-specific overrides */
        .modal-overlay-bg {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(2px);
            z-index: 50;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-overlay-bg.active { display: flex; }
        .btn-icon {
            padding: 6px;
            border-radius: 6px;
            background: transparent;
            border: none;
            color: var(--color-text-medium);
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-icon:hover { background: var(--color-primary-light); color: var(--color-primary); }
        .btn-icon.danger:hover { background: var(--color-error-bg); color: var(--color-error); }

        .empty-state {
            padding: 48px 24px;
            text-align: center;
            color: var(--color-text-light);
        }
        .empty-state iconify-icon { color: var(--color-border); margin-bottom: 12px; }

        .search-bar-wrap {
            position: relative;
            max-width: 380px;
        }
        .search-bar-wrap .search-icon-abs {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-text-light);
            pointer-events: none;
        }
        .search-bar-wrap input {
            width: 100%;
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-pill);
            padding: 9px 14px 9px 36px;
            font-size: 13px;
            outline: none;
            font-family: var(--font-sans);
            color: var(--color-text-dark);
            transition: all 0.2s;
        }
        .search-bar-wrap input:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(10,77,140,0.08);
        }
    </style>
</head>
<body>
<div class="app-shell fade-in">

    <!-- ── Sidebar ──────────────────────────────────────── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <iconify-icon icon="solar:wheel-angle-bold" width="16" style="color:#fff"></iconify-icon>
            </div>
            <span class="brand-name">AquaRoute</span>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon> Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item <%= currentPage === 'ferries' ? 'active' : '' %>">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon> Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item <%= currentPage === 'ports' ? 'active' : '' %>">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon> Port Management
            </a>
            <a href="/admin/cargo" class="nav-item <%= currentPage === 'cargo' ? 'active' : '' %>">
                <iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon> Cargo Tracking
            </a>
            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs" class="nav-item <%= currentPage === 'logs' ? 'active' : '' %>">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon> Audit Logs
            </a>
            <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
                <iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon> Users
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user ? user.name.replace(' ', '+') : 'Admin' %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user ? user.name : 'Admin User' %></div>
                    <div class="user-role"><%= user ? (user.role || 'Admin') : 'Administrator' %></div>
                </div>
                <a href="/logout" class="logout-btn">
                    <iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Content ──────────────────────────────────── -->
    <div class="main-content">

        <!-- Header -->
        <header class="top-header">
            <div class="page-title">
                <h1>Cargo Tracking</h1>
                <p>Manage and monitor all shipments</p>
            </div>
            <div class="header-actions">
                <button onclick="openAddModal()" class="btn btn-primary">
                    <iconify-icon icon="solar:add-circle-bold" width="16"></iconify-icon>
                    Add Cargo
                </button>
                <button class="icon-btn" title="Notifications">
                    <iconify-icon icon="solar:bell-bold" width="17"></iconify-icon>
                </button>
            </div>
        </header>

        <!-- Content -->
        <div class="page-content">

            <!-- Stat Cards -->
            <div class="stat-grid mb-6" style="grid-template-columns: repeat(4, 1fr);">
                <div class="stat-card primary slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:box-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Total Shipments</div>
                    <div class="stat-value"><%= stats ? stats.total : (cargo ? cargo.length : 0) %></div>
                </div>
                <div class="stat-card info slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:delivery-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">In Transit</div>
                    <div class="stat-value" style="color:var(--color-accent)"><%= stats ? stats.inTransit : 0 %></div>
                </div>
                <div class="stat-card warning slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:clock-circle-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Pending</div>
                    <div class="stat-value warning"><%= stats ? stats.pending : 0 %></div>
                </div>
                <div class="stat-card success slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:check-circle-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Delivered</div>
                    <div class="stat-value success"><%= stats ? stats.delivered : 0 %></div>
                </div>
            </div>

            <!-- Search + Table -->
            <div class="panel slide-up">
                <div class="panel-header">
                    <span class="panel-title">
                        <iconify-icon icon="solar:box-bold-duotone"></iconify-icon>
                        Active Shipments
                        <span style="color:var(--color-text-light);font-weight:400;font-size:12px;">(<%= cargo ? cargo.length : 0 %> records)</span>
                    </span>
                    <div class="search-bar-wrap">
                        <iconify-icon icon="solar:magnifer-linear" class="search-icon-abs"></iconify-icon>
                        <form action="/admin/cargo/search" method="GET">
                            <input type="text" name="query"
                                   placeholder="Search by reference or description…"
                                   value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                        </form>
                    </div>
                </div>

                <% if (cargo && cargo.length > 0) { %>
                <div style="overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Reference #</th>
                                <th>Description</th>
                                <th>Weight</th>
                                <th>Assigned Ferry</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cargo.forEach(function(item) { %>
                            <tr>
                                <td class="mono">
                                    <a href="/admin/cargo/track/<%= item.reference %>" style="color:var(--color-primary);font-weight:600;">
                                        <%= item.reference %>
                                    </a>
                                </td>
                                <td><%= item.description %></td>
                                <td class="secondary"><%= item.weight %> kg</td>
                                <td><%= item.ferryName || '—' %></td>
                                <td>
                                    <% const s = (item.status||'').toLowerCase(); %>
                                    <% if (s === 'in_transit' || s === 'in transit') { %>
                                        <span class="badge badge-in-transit">In Transit</span>
                                    <% } else if (s === 'pending' || s === 'processing') { %>
                                        <span class="badge badge-pending"><%= item.status %></span>
                                    <% } else if (s === 'delivered') { %>
                                        <span class="badge badge-delivered">Delivered</span>
                                    <% } else if (s === 'delayed') { %>
                                        <span class="badge badge-delayed">Delayed</span>
                                    <% } else { %>
                                        <span class="badge badge-neutral"><%= item.status %></span>
                                    <% } %>
                                </td>
                                <td class="secondary"><%= new Date(item.createdAt).toLocaleDateString() %></td>
                                <td style="text-align:right;">
                                    <button onclick="editCargo(this)"
                                            data-id="<%= item.id %>"
                                            data-description="<%= item.description ? item.description.replace(/"/g, '&quot;') : '' %>"
                                            data-weight="<%= item.weight || 0 %>"
                                            data-ferryid="<%= item.ferryId || '' %>"
                                            data-status="<%= item.status || 'pending' %>"
                                            class="btn-icon" title="Edit">
                                        <iconify-icon icon="solar:pen-bold" width="16"></iconify-icon>
                                    </button>
                                    <button onclick="deleteCargo('<%= item.id %>', '<%= item.reference %>')"
                                            class="btn-icon danger" title="Delete">
                                        <iconify-icon icon="solar:trash-bin-trash-bold" width="16"></iconify-icon>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="empty-state">
                    <iconify-icon icon="solar:box-bold" width="48"></iconify-icon>
                    <p style="font-weight:600;color:var(--color-text-medium);margin-top:8px;">No cargo shipments found</p>
                    <p style="font-size:12px;margin-top:4px;">Click "Add Cargo" to create a new shipment</p>
                </div>
                <% } %>
            </div>
        </div><!-- /page-content -->
    </div><!-- /main-content -->
</div><!-- /app-shell -->

<!-- Add/Edit Modal -->
<div id="cargoModal" class="modal-overlay-bg">
    <div class="modal">
        <form id="cargoForm" method="POST">
            <div class="modal-header">
                <span class="modal-title">
                    <iconify-icon icon="solar:box-bold-duotone"></iconify-icon>
                    <span id="modalTitle">Add New Cargo</span>
                </span>
                <button type="button" onclick="closeModal()" class="modal-close">
                    <iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cargoId" name="id">

                <div class="form-group">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" id="description" name="description" rows="2" required></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label" for="weight">Weight (kg)</label>
                    <input class="form-control" type="number" id="weight" name="weight" step="0.1" min="0" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="ferryId">Assign to Ferry</label>
                    <select class="form-control" id="ferryId" name="ferryId">
                        <option value="">— Unassigned —</option>
                        <% if (ferries) { %>
                            <% ferries.forEach(function(f) { %>
                            <option value="<%= f.id %>"><%= f.name %> — <%= f.route %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="status">Status</label>
                    <select class="form-control" id="status" name="status" required>
                        <option value="pending">Pending</option>
                        <option value="processing">Processing</option>
                        <option value="in_transit">In Transit</option>
                        <option value="delivered">Delivered</option>
                        <option value="delayed">Delayed</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Cargo</button>
            </div>
        </form>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add New Cargo';
        document.getElementById('cargoForm').action = '/admin/cargo/add';
        document.getElementById('cargoId').value = '';
        document.getElementById('description').value = '';
        document.getElementById('weight').value = '';
        document.getElementById('ferryId').value = '';
        document.getElementById('status').value = 'pending';
        document.getElementById('cargoModal').classList.add('active');
    }

    function editCargo(button) {
        var id         = button.getAttribute('data-id');
        var description = button.getAttribute('data-description');
        var weight     = button.getAttribute('data-weight');
        var ferryId    = button.getAttribute('data-ferryid');
        var status     = button.getAttribute('data-status');

        document.getElementById('modalTitle').textContent = 'Edit Cargo';
        document.getElementById('cargoForm').action = '/admin/cargo/' + id + '/update';
        document.getElementById('cargoId').value = id;
        document.getElementById('description').value = description;
        document.getElementById('weight').value = weight;
        document.getElementById('ferryId').value = ferryId || '';
        document.getElementById('status').value = status || 'pending';
        document.getElementById('cargoModal').classList.add('active');
    }

    function closeModal() {
        document.getElementById('cargoModal').classList.remove('active');
    }

    function deleteCargo(id, reference) {
        if (confirm('Delete cargo ' + reference + '? This action cannot be undone.')) {
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/admin/cargo/' + id + '/delete';
            document.body.appendChild(form);
            form.submit();
        }
    }

    function showToast(msg, type) {
        const toast = document.getElementById('toast');
        const icon  = document.getElementById('toast-icon');
        const text  = document.getElementById('toast-message');
        text.innerText = msg;
        toast.className = 'toast ' + (type||'info');
        icon.className  = 'toast-icon ' + (type||'info');
        if (type === 'success') icon.setAttribute('icon', 'solar:check-circle-bold');
        else if (type === 'error') icon.setAttribute('icon', 'solar:danger-circle-bold');
        else icon.setAttribute('icon', 'solar:info-circle-bold');
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3500);
    }

    <% if (typeof message !== 'undefined' && message) { %>
        window.onload = function() { showToast('<%= message %>', 'success'); };
    <% } %>

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeModal();
    });
</script>
</body>
</html>