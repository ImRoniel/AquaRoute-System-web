<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute Admin</title>

    <!-- AquaRoute Maritime Theme -->
    <link rel="stylesheet" href="/css/admin-theme.css">

    <!-- Tailwind (utilities only — layout) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            corePlugins: { preflight: false },
            theme: { extend: { colors: { primary: '#0A4D8C' } } }
        }
    </script>
</head>
<body>
<div class="app-shell fade-in">

    <!-- ── Sidebar ──────────────────────────────────────── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <iconify-icon icon="solar:wheel-angle-bold" width="16" style="color:#fff"></iconify-icon>
            </div>
            <span class="brand-name">AquaRoute</span>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon>
                Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item <%= currentPage === 'ferries' ? 'active' : '' %>">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon>
                Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item <%= currentPage === 'ports' ? 'active' : '' %>">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon>
                Port Management
            </a>
            <a href="/admin/cargo" class="nav-item <%= currentPage === 'cargo' ? 'active' : '' %>">
                <iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon>
                Cargo Tracking
            </a>

            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs" class="nav-item <%= currentPage === 'logs' ? 'active' : '' %>">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon>
                Audit Logs
            </a>
            <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
                <iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon>
                Users
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user.name.replace(' ', '+') %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user.name %></div>
                    <div class="user-role"><%= user.role || 'Admin' %></div>
                </div>
                <a href="/logout" class="logout-btn">
                    <iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon>
                </a>
            </div>
        </div>
    </aside>

    <!-- ── Main Content ──────────────────────────────────── -->
    <div class="main-content">

        <!-- Header -->
        <header class="top-header">
            <div class="page-title">
                <h1>Dashboard</h1>
                <p>Welcome back, <%= user.name %></p>
            </div>
            <div class="header-actions">
                <div class="search-wrap">
                    <iconify-icon icon="solar:magnifer-linear" class="search-icon"></iconify-icon>
                    <input type="text" class="search-input" placeholder="Search…">
                </div>
                <button class="icon-btn" title="Notifications">
                    <iconify-icon icon="solar:bell-bold" width="17"></iconify-icon>
                </button>
            </div>
        </header>

        <!-- Content -->
        <div class="page-content">

            <!-- Stat Cards -->
            <div class="stat-grid mb-6" style="grid-template-columns: repeat(5, 1fr);">

                <div class="stat-card primary slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:users-group-rounded-bold" width="20"></iconify-icon></div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value"><%= stats.totalUsers || 0 %></div>
                </div>

                <div class="stat-card info slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:ship-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Total Fleet</div>
                    <div class="stat-value"><%= stats.totalFleet || 0 %></div>
                </div>

                <div class="stat-card success slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:check-circle-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">On Time</div>
                    <div class="stat-value success"><%= stats.onTime || 0 %></div>
                </div>

                <div class="stat-card warning slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:clock-circle-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Delayed</div>
                    <div class="stat-value warning"><%= stats.delayed || 0 %></div>
                </div>

                <div class="stat-card danger slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:danger-circle-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Suspended</div>
                    <div class="stat-value danger"><%= stats.suspended || 0 %></div>
                </div>
            </div>

            <!-- Two-column grid -->
            <div style="display:grid; grid-template-columns: 1fr 340px; gap:20px;">

                <!-- Fleet Status Table -->
                <div class="panel slide-up">
                    <div class="panel-header">
                        <span class="panel-title">
                            <iconify-icon icon="solar:map-bold-duotone"></iconify-icon>
                            Live Fleet Status
                        </span>
                        <a href="/admin/ferries" class="panel-action">View all →</a>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Vessel</th>
                                    <th>Route</th>
                                    <th>Status</th>
                                    <th>ETA</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% ferries.forEach(f => { %>
                                <tr>
                                    <td style="font-weight:600;"><%= f.name %></td>
                                    <td class="secondary"><%= f.route %></td>
                                    <td>
                                        <% if (f.status === 'on_time' || f.status === 'active') { %>
                                            <span class="badge badge-on-time">On Time</span>
                                        <% } else if (f.status === 'delayed') { %>
                                            <span class="badge badge-delayed">Delayed</span>
                                        <% } else if (f.status === 'docked' || f.status === 'arrived') { %>
                                            <span class="badge badge-docked">Docked</span>
                                        <% } else { %>
                                            <span class="badge badge-suspended"><%= f.status || 'Suspended' %></span>
                                        <% } %>
                                    </td>
                                    <td class="secondary"><%= f.eta %> min</td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="panel slide-up">
                    <div class="panel-header">
                        <span class="panel-title">
                            <iconify-icon icon="solar:clock-square-bold-duotone"></iconify-icon>
                            Recent Activity
                        </span>
                    </div>
                    <div class="activity-list">
                        <% logs.forEach(log => { %>
                        <div class="activity-item">
                            <div class="activity-dot">
                                <iconify-icon icon="solar:<%=
                                    log.action.includes('Delayed')  ? 'clock-circle-bold' :
                                    log.action.includes('Update')   ? 'check-circle-bold' :
                                    'add-circle-bold'
                                %>" width="14"></iconify-icon>
                            </div>
                            <div class="activity-text">
                                <div class="action"><%= log.action %></div>
                                <div class="time"><%= log.time %></div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div><!-- /page-content -->
    </div><!-- /main-content -->
</div><!-- /app-shell -->

<!-- Toast -->
<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    function showToast(msg, type = 'info') {
        const toast = document.getElementById('toast');
        const icon  = document.getElementById('toast-icon');
        const text  = document.getElementById('toast-message');
        text.innerText = msg;
        toast.className = 'toast ' + type;
        if (type === 'success') icon.setAttribute('icon', 'solar:check-circle-bold');
        else if (type === 'error') icon.setAttribute('icon', 'solar:danger-circle-bold');
        else icon.setAttribute('icon', 'solar:info-circle-bold');
        icon.className = 'toast-icon ' + type;
        setTimeout(() => toast.classList.remove('show'), 50);
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3500);
    }
</script>
</body>
</html>