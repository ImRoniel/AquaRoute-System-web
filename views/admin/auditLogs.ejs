<!-- views/admin/auditLogs.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Audit Logs' %> - AquaRoute</title>
    <link rel="stylesheet" href="/css/admin-theme.css">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Filter tabs */
        .filter-tabs { display:flex; gap:8px; flex-wrap:wrap; padding-bottom:16px; border-bottom:1.5px solid var(--color-border); margin-bottom:20px; }
        .filter-tab { padding:6px 14px; border-radius:var(--radius-pill); font-size:13px; font-weight:500; color:var(--color-text-medium); background:var(--color-surface); border:1.5px solid var(--color-border); cursor:pointer; transition:all 0.15s; }
        .filter-tab:hover { border-color:var(--color-primary); color:var(--color-primary); }
        .filter-tab.active { background:var(--color-primary); color:#fff; border-color:var(--color-primary); }

        /* Action type badges */
        .atype { padding:3px 10px; border-radius:var(--radius-pill); font-size:11px; font-weight:600; display:inline-block; white-space:nowrap; }
        .atype-status  { background:#FFF3E0; color:#E65100; }
        .atype-cargo   { background:var(--color-primary-light); color:var(--color-primary); }
        .atype-ferry   { background:var(--color-success-bg); color:var(--color-success); }
        .atype-route   { background:#E3F2FD; color:#1565C0; }
        .atype-user    { background:#F3E5F5; color:#6A1B9A; }
        .atype-system  { background:#ECEFF1; color:#546E7A; }

        /* Admin avatar */
        .adm-av { width:28px; height:28px; border-radius:50%; background:var(--color-primary-light); display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:var(--color-primary); border:1.5px solid var(--color-border); flex-shrink:0; }

        /* Details tooltip */
        .det-wrap { max-width:280px; position:relative; }
        .det-text { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:help; font-size:12px; }
        .det-text:hover::after { content:attr(data-full); position:absolute; left:0; top:100%; background:var(--color-text-dark); color:#fff; padding:8px 10px; border-radius:8px; font-size:11px; z-index:20; white-space:normal; max-width:320px; line-height:1.5; }

        /* Date range inputs */
        .date-input { font-size:12px; padding:7px 10px; border:1.5px solid var(--color-border); border-radius:8px; outline:none; font-family:var(--font-sans); background:var(--color-surface); color:var(--color-text-dark); transition:border-color 0.15s; }
        .date-input:focus { border-color:var(--color-primary); }

        /* Toolbar */
        .toolbar { display:flex; flex-wrap:wrap; gap:10px; align-items:center; background:var(--color-surface); border:1.5px solid var(--color-border); border-radius:var(--radius-lg); padding:14px 16px; margin-bottom:20px; }
        .search-field { flex:1; min-width:200px; display:flex; align-items:center; gap:8px; background:var(--color-bg); border:1.5px solid var(--color-border); border-radius:var(--radius-pill); padding:8px 14px; }
        .search-field input { border:none; outline:none; width:100%; font-size:13px; background:transparent; font-family:var(--font-sans); color:var(--color-text-dark); }

        /* Pagination */
        .pag { display:flex; justify-content:flex-end; gap:4px; padding:14px 20px; border-top:1.5px solid var(--color-border); }
        .pag-btn { width:30px; height:30px; display:flex; align-items:center; justify-content:center; border-radius:6px; border:1.5px solid var(--color-border); background:var(--color-surface); color:var(--color-text-medium); font-size:13px; cursor:pointer; transition:all 0.15s; }
        .pag-btn:hover:not(:disabled) { background:var(--color-primary-light); border-color:var(--color-primary); color:var(--color-primary); }
        .pag-btn.active { background:var(--color-primary); color:#fff; border-color:var(--color-primary); }
        .pag-btn:disabled { opacity:0.4; cursor:not-allowed; }
    </style>
</head>
<body>
<div class="app-shell fade-in">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><img src="/aquaRoute_logo.svg" alt="AquaRoute Logo" style="width:16px; height:16px; filter:brightness(0) invert(1);"></div>
            <span class="brand-name">AquaRoute</span>
        </div>
        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item"><iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon> Dashboard</a>
            <a href="/admin/ferries"   class="nav-item"><iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon> Ferry Management</a>
            <a href="/admin/ports"     class="nav-item"><iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon> Port Management</a>
            <a href="/admin/cargo"     class="nav-item"><iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon> Cargo Tracking</a>
            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs"   class="nav-item active"><iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon> Audit Logs</a>
            <a href="/admin/users"  class="nav-item"><iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon> Users</a>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user ? user.name.replace(' ','+') : 'Admin' %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user ? user.name : 'Admin User' %></div>
                    <div class="user-role"><%= user ? (user.role||'Admin') : 'Administrator' %></div>
                </div>
                <a href="/logout" class="logout-btn"><iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon></a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <header class="top-header">
            <div class="page-title">
                <h1>Audit Logs</h1>
                <p>Complete history of administrative actions and system events</p>
            </div>
            <div class="header-actions">
                <button class="icon-btn"><iconify-icon icon="solar:bell-bold" width="17"></iconify-icon></button>
            </div>
        </header>

        <div class="page-content">

            <!-- Filter Tabs -->
            <div class="filter-tabs">
                <button class="filter-tab active" onclick="filterLogs('all')">All Activity</button>
                <button class="filter-tab" onclick="filterLogs('status')">Status Changes</button>
                <button class="filter-tab" onclick="filterLogs('cargo')">Cargo Operations</button>
                <button class="filter-tab" onclick="filterLogs('ferry')">Ferry Management</button>
                <button class="filter-tab" onclick="filterLogs('route')">Route Advisories</button>
                <button class="filter-tab" onclick="filterLogs('system')">System Events</button>
            </div>

            <!-- Toolbar -->
            <div class="toolbar">
                <!-- Search -->
                <div class="search-field">
                    <iconify-icon icon="solar:magnifer-linear" style="color:var(--color-text-light);flex-shrink:0;"></iconify-icon>
                    <input type="text" id="searchLogs" placeholder="Search by admin, action, or details…" onkeyup="searchLogs()">
                </div>

                <!-- Date Range -->
                <form action="/admin/logs" method="GET" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <input type="date" name="start" value="<%= typeof start !== 'undefined' ? start : '' %>" class="date-input">
                    <span style="font-size:12px;color:var(--color-text-light);">to</span>
                    <input type="date" name="end" value="<%= typeof end !== 'undefined' ? end : '' %>" class="date-input">
                    <button type="submit" class="btn btn-primary" style="padding:7px 14px;font-size:13px;">Apply</button>
                    <% if (typeof start !== 'undefined' && (start || end)) { %>
                    <a href="/admin/logs" class="btn btn-secondary" style="padding:7px 14px;font-size:13px;">Reset</a>
                    <% } %>
                </form>

                <!-- Actions -->
                <div style="display:flex;gap:8px;margin-left:auto;">
                    <button onclick="exportLogs()" class="btn btn-secondary" style="gap:6px;">
                        <iconify-icon icon="solar:export-bold" width="14"></iconify-icon> Export CSV
                    </button>
                    <button onclick="clearLogs()" class="btn" style="gap:6px;background:var(--color-error-bg);color:var(--color-error);border:1.5px solid var(--color-error);border-radius:var(--radius-pill);padding:8px 14px;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;">
                        <iconify-icon icon="solar:trash-bin-bold" width="14"></iconify-icon> Clear History
                    </button>
                </div>
            </div>

            <!-- Table -->
            <div class="panel slide-up" style="padding:0;overflow:hidden;">
                <div class="panel-header" style="border-radius:0;">
                    <span class="panel-title">
                        <iconify-icon icon="solar:clipboard-list-bold-duotone"></iconify-icon>
                        System Activity Logs
                        <span style="color:var(--color-text-light);font-weight:400;font-size:12px;">(<%= logs ? logs.length : 0 %> records)</span>
                    </span>
                    <span style="font-size:11px;color:var(--color-text-light);">Last updated: <%= new Date().toLocaleString() %></span>
                </div>

                <% if (logs && logs.length > 0) { %>
                <div style="overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Admin</th>
                                <th>Action Type</th>
                                <th>Action</th>
                                <th>Details</th>
                                <th style="text-align:right;">Timestamp</th>
                            </tr>
                        </thead>
                        <tbody id="logsTableBody">
                            <% logs.forEach(function(log) {
                                let aType = 'system';
                                let aClass = 'atype-system';
                                let aLabel = 'System Event';
                                const act = (log.action || '').toLowerCase();
                                if (act.includes('status') || act.includes('suspended')) { aType='status'; aClass='atype-status'; aLabel='Status Change'; }
                                else if (act.includes('cargo'))  { aType='cargo'; aClass='atype-cargo'; aLabel='Cargo Operation'; }
                                else if (act.includes('ferry') || act.includes('vessel')) { aType='ferry'; aClass='atype-ferry'; aLabel='Ferry Management'; }
                                else if (act.includes('route') || act.includes('advisory')) { aType='route'; aClass='atype-route'; aLabel='Route Advisory'; }
                                else if (act.includes('user'))   { aType='user'; aClass='atype-user'; aLabel='User Management'; }
                            %>
                            <tr data-action-type="<%= aType %>">
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div class="adm-av"><%= log.admin ? log.admin.charAt(0).toUpperCase() : 'S' %></div>
                                        <span style="font-weight:500;"><%= log.admin || 'System' %></span>
                                    </div>
                                </td>
                                <td><span class="atype <%= aClass %>"><%= aLabel %></span></td>
                                <td style="font-weight:500;font-size:13px;"><%= log.action || 'Unknown Action' %></td>
                                <td>
                                    <div class="det-wrap">
                                        <div class="det-text" data-full="<%= log.details || 'No additional details' %>">
                                            <%= log.details ? (log.details.length > 55 ? log.details.substring(0, 55) + '…' : log.details) : '—' %>
                                        </div>
                                    </div>
                                </td>
                                <td style="text-align:right;">
                                    <span style="font-size:12px;color:var(--color-primary);font-family:monospace;">
                                        <%= log.timestamp ? log.timestamp.toLocaleString() : 'Just now' %>
                                    </span>
                                    <% if (log.timestamp) { %>
                                    <br><span style="font-size:10px;color:var(--color-text-light);"><%= log.timeFormatted %></span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pag">
                    <button class="pag-btn" onclick="previousPage()" <%= page <= 1 ? 'disabled' : '' %>>
                        <iconify-icon icon="solar:alt-arrow-left-bold" width="13"></iconify-icon>
                    </button>
                    <button class="pag-btn active">1</button>
                    <button class="pag-btn">2</button>
                    <button class="pag-btn">3</button>
                    <button class="pag-btn" onclick="nextPage()">
                        <iconify-icon icon="solar:alt-arrow-right-bold" width="13"></iconify-icon>
                    </button>
                </div>

                <% } else { %>
                <div style="padding:48px;text-align:center;color:var(--color-text-light);">
                    <iconify-icon icon="solar:clipboard-list-bold" width="48" style="color:var(--color-primary);opacity:0.4;"></iconify-icon>
                    <p style="font-weight:600;color:var(--color-text-medium);margin-top:10px;">No audit logs available</p>
                    <p style="font-size:12px;margin-top:4px;">Actions will appear here as they occur</p>
                    <div style="margin-top:16px;padding:12px 16px;background:var(--color-primary-light);border-radius:var(--radius-lg);text-align:left;font-size:12px;color:var(--color-text-medium);max-width:360px;margin-left:auto;margin-right:auto;">
                        <p style="font-weight:600;color:var(--color-text-dark);margin-bottom:6px;">What gets logged:</p>
                        <ul style="list-style:disc;padding-left:16px;line-height:2;">
                            <li>Admin status changes (On Time → Delayed → Suspended)</li>
                            <li>Cargo assignments and tracking updates</li>
                            <li>Ferry route modifications</li>
                            <li>Weather advisory postings</li>
                            <li>Port status updates</li>
                            <li>User account management</li>
                        </ul>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    function showToast(msg, type) {
        const t=document.getElementById('toast');
        const ic=document.getElementById('toast-icon');
        document.getElementById('toast-message').innerText=msg;
        t.className='toast '+(type||'info');
        ic.className='toast-icon '+(type||'info');
        if(type==='success') ic.setAttribute('icon','solar:check-circle-bold');
        else if(type==='error') ic.setAttribute('icon','solar:danger-circle-bold');
        else ic.setAttribute('icon','solar:info-circle-bold');
        t.classList.add('show');
        setTimeout(()=>t.classList.remove('show'),3500);
    }

    function filterLogs(type) {
        document.querySelectorAll('.filter-tab').forEach(tab => {
            const matches = (type==='all' && tab.textContent.includes('All')) ||
                            tab.textContent.toLowerCase().includes(type);
            tab.classList.toggle('active', matches);
        });
        document.querySelectorAll('#logsTableBody tr').forEach(row => {
            row.style.display = (type==='all' || row.getAttribute('data-action-type')===type) ? '' : 'none';
        });
        if (type !== 'all') showToast('Filtered to show ' + type + ' logs', 'info');
    }

    function searchLogs() {
        const q=document.getElementById('searchLogs').value.toLowerCase();
        document.querySelectorAll('#logsTableBody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    function exportLogs() {
        const rows=document.querySelectorAll('#logsTableBody tr');
        if (!rows.length) { showToast('No logs to export','info'); return; }
        let csv='Admin,Action Type,Action,Details,Timestamp\n';
        rows.forEach(row => {
            if (row.style.display==='none') return;
            const cols=row.querySelectorAll('td');
            const get=i=>cols[i].textContent.trim().replace(/,/g,';');
            csv+=`"${get(0)}","${get(1)}","${get(2)}","${get(3)}","${get(4)}"\n`;
        });
        const a=document.createElement('a');
        a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
        a.download=`audit-logs-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
        showToast('Logs exported successfully','success');
    }

    async function clearLogs() {
        if (!confirm('Clear all audit logs? This action cannot be undone.')) return;
        try {
            const r=await fetch('/api/admin/logs/clear',{method:'POST',headers:{'Content-Type':'application/json'}});
            const res=await r.json();
            if (res.success) { showToast(res.message||'Logs cleared','success'); setTimeout(()=>location.reload(),1500); }
            else showToast(res.error||'Failed to clear logs','error');
        } catch(e) { showToast('An error occurred','error'); }
    }

    function previousPage() { showToast('Pagination handled by server filters.','info'); }
    function nextPage()     { showToast('Pagination handled by server filters.','info'); }
</script>
</body>
</html>