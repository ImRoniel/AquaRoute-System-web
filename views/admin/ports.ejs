<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>

    <!-- AquaRoute Maritime Theme -->
    <link rel="stylesheet" href="/css/admin-theme.css">

    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* ---- Port Grid ---- */
        .ports-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }
        @media (min-width: 640px)  { .ports-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (min-width: 1024px) { .ports-grid { grid-template-columns: repeat(3, 1fr); } }

        /* ---- Port Card ---- */
        .port-card {
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 20px;
            transition: all 0.18s ease;
            position: relative;
        }
        .port-card:hover {
            border-color: var(--color-primary);
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
        }
        .port-icon {
            width: 44px; height: 44px;
            border-radius: 12px;
            background: var(--color-primary-light);
            display: flex; align-items: center; justify-content: center;
            color: var(--color-primary);
        }

        /* ---- Status Badges (port-specific) ---- */
        .port-badge {
            padding: 4px 12px;
            border-radius: var(--radius-pill);
            font-size: 12px; font-weight: 600;
            display: inline-flex; align-items: center; gap: 5px;
        }
        .port-badge-open    { background: var(--color-success-bg); color: var(--color-success); }
        .port-badge-limited { background: var(--color-warning-bg); color: var(--color-warning); }
        .port-badge-closed  { background: var(--color-error-bg);   color: var(--color-error); }

        /* ---- Update Button ---- */
        .update-btn {
            padding: 5px 14px;
            border-radius: var(--radius-pill);
            font-size: 12px; font-weight: 600;
            border: 1.5px solid var(--color-border);
            background: var(--color-primary-light);
            color: var(--color-primary);
            cursor: pointer; transition: all 0.15s;
        }
        .update-btn:hover {
            background: var(--color-primary);
            color: #fff; border-color: var(--color-primary);
        }
        .update-btn:disabled { opacity: .5; cursor: not-allowed; }

        /* ---- Dropdown Menu ---- */
        .relative-menu { position: relative; }
        .menu-btn {
            padding: 4px 6px; border-radius: 6px; border: none;
            background: transparent; color: var(--color-text-light);
            cursor: pointer; transition: all 0.15s;
        }
        .menu-btn:hover { background: var(--color-primary-light); color: var(--color-primary); }
        .dropdown-menu {
            position: absolute; right: 0; top: 100%;
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: 10px;
            box-shadow: var(--shadow-lg);
            min-width: 148px; z-index: 100;
            display: none; flex-direction: column; padding: 4px 0;
        }
        .dropdown-menu.show { display: flex; }
        .dropdown-item {
            padding: 8px 14px; font-size: 13px;
            color: var(--color-text-dark);
            display: flex; align-items: center; gap: 8px;
            transition: all 0.12s; border: none; background: none;
            cursor: pointer; width: 100%; text-align: left;
        }
        .dropdown-item:hover { background: var(--color-primary-light); color: var(--color-primary); }
        .dropdown-item.danger { color: var(--color-error); }
        .dropdown-item.danger:hover { background: var(--color-error-bg); }

        /* ---- Weather Pill ---- */
        .weather-text {
            font-size: 12px; color: var(--color-text-light);
            display: flex; align-items: center; flex-wrap: wrap; gap: 5px;
        }
        .weather-pill {
            background: var(--color-bg);
            border: 1px solid var(--color-border);
            border-radius: 4px; padding: 2px 7px;
            font-size: 11px;
        }

        /* ---- Search Bar ---- */
        .port-search-wrap { position: relative; }
        .port-search-wrap .si { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-light); pointer-events: none; }
        .port-search-wrap input {
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-pill);
            padding: 9px 14px 9px 36px;
            font-size: 13px; outline: none;
            font-family: var(--font-sans); color: var(--color-text-dark);
            background: var(--color-surface);
            width: 300px; transition: all 0.2s;
        }
        .port-search-wrap input:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(10,77,140,0.08); }
        .search-spinner { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); display: none; }

        /* ---- Modal overlay ---- */
        .modal-overlay-bg {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.45); backdrop-filter: blur(2px);
            z-index: 200; align-items: center; justify-content: center; padding: 20px;
        }
        .modal-overlay-bg.active { display: flex; }

        /* ---- Loading overlay ---- */
        .loading-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(255,255,255,0.65); backdrop-filter: blur(3px);
            z-index: 300; justify-content: center; align-items: center;
        }
        .loading-overlay.active { display: flex; }
        .spinner-ring {
            width: 48px; height: 48px; border-radius: 50%;
            border: 4px solid var(--color-border);
            border-top-color: var(--color-primary);
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ---- No Results ---- */
        .no-results {
            grid-column: 1/-1;
            padding: 48px; text-align: center;
            color: var(--color-text-light);
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-lg);
            display: none;
        }
    </style>
</head>
<body>
<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner-ring"></div>
</div>

<div class="app-shell fade-in">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><iconify-icon icon="solar:wheel-angle-bold" width="16" style="color:#fff"></iconify-icon></div>
            <span class="brand-name">AquaRoute</span>
        </div>
        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item <%= currentPage==='dashboard'?'active':'' %>">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon> Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item <%= currentPage==='ferries'?'active':'' %>">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon> Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item <%= currentPage==='ports'?'active':'' %>">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon> Port Management
            </a>
            <a href="/admin/cargo" class="nav-item <%= currentPage==='cargo'?'active':'' %>">
                <iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon> Cargo Tracking
            </a>
            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs" class="nav-item <%= currentPage==='logs'?'active':'' %>">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon> Audit Logs
            </a>
            <a href="/admin/users" class="nav-item <%= currentPage==='users'?'active':'' %>">
                <iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon> Users
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user.name.replace(' ','+') %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user.name %></div>
                    <div class="user-role"><%= user.role || 'Admin' %></div>
                </div>
                <a href="/logout" class="logout-btn"><iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon></a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <header class="top-header">
            <div class="page-title">
                <h1>Port Management</h1>
                <p>Control port operations and advisories</p>
            </div>
            <div class="header-actions">
                <button onclick="openAddModal()" class="btn btn-primary">
                    <iconify-icon icon="solar:add-circle-bold" width="16"></iconify-icon>
                    Add Port
                </button>
                <button class="icon-btn"><iconify-icon icon="solar:bell-bold" width="17"></iconify-icon></button>
            </div>
        </header>

        <div class="page-content">

            <!-- Toolbar -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
                <div class="port-search-wrap">
                    <iconify-icon icon="solar:magnifer-linear" class="si"></iconify-icon>
                    <input type="text" id="port-search" onkeyup="debounceSearch()"
                           placeholder="Search all ports (e.g., Dagupan, Manila)…"
                           autocomplete="off">
                    <div id="searchLoading" class="search-spinner">
                        <div style="width:16px;height:16px;border-radius:50%;border:2px solid var(--color-border);border-top-color:var(--color-primary);animation:spin 0.8s linear infinite;"></div>
                    </div>
                </div>
                <span style="font-size:13px;color:var(--color-text-light);">
                    <span id="resultCount"><%= ports.length %></span> ports loaded
                </span>
            </div>

            <!-- Ports Grid: initial paginated view -->
            <div class="ports-grid" id="ports-grid">
                <% ports.forEach(p => { %>
                <div class="port-card" data-id="<%= p.id %>">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
                        <div class="port-icon">
                            <iconify-icon icon="solar:anchor-bold-duotone" width="20"></iconify-icon>
                        </div>
                        <div class="relative-menu">
                            <button class="menu-btn" onclick="toggleMenu('<%= p.id %>')">
                                <iconify-icon icon="solar:menu-dots-bold" width="18"></iconify-icon>
                            </button>
                            <div id="dropdown-<%= p.id %>" class="dropdown-menu">
                                <button onclick="openEditModal('<%= p.id %>', '<%= p.name ? p.name.replace(/'/g, `\\'`) : "" %>', '<%= p.type %>', '<%= p.status %>', <%= p.lat || 0 %>, <%= p.lng || 0 %>, '<%= p.location ? p.location.replace(/'/g, `\\'`) : "" %>')" class="dropdown-item">
                                    <iconify-icon icon="solar:pen-bold" width="14"></iconify-icon> Edit Port
                                </button>
                                <button onclick="togglePortStatus('<%= p.id %>')" class="dropdown-item">
                                    <iconify-icon icon="solar:refresh-circle-bold" width="14"></iconify-icon> Toggle Status
                                </button>
                                <button onclick="deletePort('<%= p.id %>')" class="dropdown-item danger">
                                    <iconify-icon icon="solar:trash-bin-trash-bold" width="14"></iconify-icon> Delete Port
                                </button>
                            </div>
                        </div>
                    </div>

                    <h4 style="font-weight:600;font-size:15px;margin-bottom:6px;color:var(--color-text-dark);"><%= p.name %></h4>

                    <div class="weather-text" style="margin-bottom:14px;">
                        <% if (p.weatherData) { %>
                            <span class="weather-pill"><%= p.weatherData.icon %> <%= p.weatherData.temperature %>°C</span>
                            <span class="weather-pill">🌊 <%= p.weatherData.waves || 'N/A' %></span>
                            <span class="weather-pill">💨 <%= p.weatherData.windSpeed %></span>
                        <% } else { %>
                            <iconify-icon icon="solar:cloud-sun-2-bold" width="14"></iconify-icon>
                            Weather: Unknown
                        <% } %>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1.5px solid var(--color-border);">
                        <% if (p.status === 'open') { %>
                            <span class="port-badge port-badge-open">
                                <iconify-icon icon="solar:check-circle-bold" width="12"></iconify-icon> Open
                            </span>
                        <% } else if (p.status === 'limited') { %>
                            <span class="port-badge port-badge-limited">
                                <iconify-icon icon="solar:danger-triangle-bold" width="12"></iconify-icon> Limited
                            </span>
                        <% } else { %>
                            <span class="port-badge port-badge-closed">
                                <iconify-icon icon="solar:forbidden-circle-bold" width="12"></iconify-icon> Closed
                            </span>
                        <% } %>
                        <button onclick="togglePortStatus('<%= p.id %>')" class="update-btn">Update</button>
                    </div>
                </div>
                <% }) %>
            </div>

            <!-- Search Results Grid (hidden by default) -->
            <div class="ports-grid" id="search-results-grid" style="display:none;"></div>

            <!-- No Results -->
            <div id="noResults" class="no-results">
                <iconify-icon icon="solar:map-point-wave-bold-duotone" width="48" style="color:var(--color-primary);opacity:.4;margin-bottom:10px;"></iconify-icon>
                <p style="font-weight:600;color:var(--color-text-medium);">No ports found</p>
                <p style="font-size:12px;margin-top:4px;">Try searching with a different name or location.</p>
            </div>

            <!-- Load More -->
            <% if (lastVisible) { %>
            <div style="text-align:center;margin-top:20px;" id="loadMoreContainer">
                <button onclick="loadMorePorts()" class="btn btn-secondary" style="padding:10px 28px;">
                    <iconify-icon icon="solar:refresh-bold" width="14"></iconify-icon>
                    Load More Ports
                </button>
            </div>
            <% } %>

        </div><!-- /page-content -->
    </div><!-- /main-content -->
</div><!-- /app-shell -->

<!-- ===================== ADD PORT MODAL ===================== -->
<div id="addPortModal" class="modal-overlay-bg">
    <div class="modal" style="max-width:500px;">
        <div class="modal-header">
            <span class="modal-title"><iconify-icon icon="solar:anchor-bold-duotone"></iconify-icon> Add New Port</span>
            <button type="button" onclick="closeAddModal()" class="modal-close">
                <iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon>
            </button>
        </div>
        <form id="addPortForm" action="/admin/ports/add" method="POST">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label" for="addName">Port Name *</label>
                    <input type="text" class="form-control" id="addName" name="name" required placeholder="e.g. Dagupan Ferry Terminal">
                </div>
                <div class="form-group">
                    <label class="form-label" for="addLocation">Location / Area</label>
                    <input type="text" class="form-control" id="addLocation" name="location" placeholder="e.g. Pangasinan">
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="addStatus">Status</label>
                        <select class="form-control" id="addStatus" name="status">
                            <option value="open">Open</option>
                            <option value="limited">Limited</option>
                            <option value="closed">Closed</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="addType">Type</label>
                        <select class="form-control" id="addType" name="type">
                            <option value="ferry_terminal">Ferry Terminal</option>
                            <option value="pier">Pier</option>
                            <option value="dock">Dock</option>
                            <option value="unknown">Unknown</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="addLat">Latitude *</label>
                        <input type="number" step="any" class="form-control" id="addLat" name="lat" required placeholder="e.g. 16.0433">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="addLng">Longitude *</label>
                        <input type="number" step="any" class="form-control" id="addLng" name="lng" required placeholder="e.g. 120.3333">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeAddModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Port</button>
            </div>
        </form>
    </div>
</div>

<!-- ===================== EDIT PORT MODAL ===================== -->
<div id="editPortModal" class="modal-overlay-bg">
    <div class="modal" style="max-width:500px;">
        <div class="modal-header">
            <span class="modal-title"><iconify-icon icon="solar:pen-bold"></iconify-icon> Edit Port</span>
            <button type="button" onclick="closeEditModal()" class="modal-close">
                <iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon>
            </button>
        </div>
        <form id="editPortForm" method="POST">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label" for="editName">Port Name *</label>
                    <input type="text" class="form-control" id="editName" name="name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="editLocation">Location / Area</label>
                    <input type="text" class="form-control" id="editLocation" name="location">
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="editStatus">Status</label>
                        <select class="form-control" id="editStatus" name="status">
                            <option value="open">Open</option>
                            <option value="limited">Limited</option>
                            <option value="closed">Closed</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="editType">Type</label>
                        <select class="form-control" id="editType" name="type">
                            <option value="ferry_terminal">Ferry Terminal</option>
                            <option value="pier">Pier</option>
                            <option value="dock">Dock</option>
                            <option value="unknown">Unknown</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="editLat">Latitude *</label>
                        <input type="number" step="any" class="form-control" id="editLat" name="lat" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="editLng">Longitude *</label>
                        <input type="number" step="any" class="form-control" id="editLng" name="lng" required>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeEditModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    // ---- State ----
    let lastVisibleId = '<%= lastVisible ? lastVisible : "" %>';
    let searchTimeout;

    // ---- Search ----
    function debounceSearch() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(performSearch, 500);
    }

    async function performSearch() {
        const query = document.getElementById('port-search').value.trim();
        if (!query) { window.location.reload(); return; }
        document.getElementById('searchLoading').style.display = 'block';
        try {
            const r = await fetch(`/api/ports/search?q=${encodeURIComponent(query)}`);
            const data = await r.json();
            renderPorts(data, 'search-results-grid');
        } catch(e) {
            showToast('Error searching ports', 'error');
        } finally {
            document.getElementById('searchLoading').style.display = 'none';
        }
    }

    // ---- Render port cards dynamically ----
    function renderPorts(ports, containerId) {
        const initial   = document.getElementById('ports-grid');
        const results   = document.getElementById('search-results-grid');
        const noResults = document.getElementById('noResults');
        const lmc       = document.getElementById('loadMoreContainer');
        const rc        = document.getElementById('resultCount');

        if (ports.length === 0) {
            initial.style.display = 'none'; results.style.display = 'none';
            noResults.style.display = 'block'; if(lmc) lmc.style.display = 'none';
            rc.innerText = '0'; return;
        }
        noResults.style.display = 'none';
        if (containerId === 'search-results-grid') {
            initial.style.display = 'none';
            results.style.display = 'grid';
            if(lmc) lmc.style.display = 'none';
            rc.innerText = ports.length;
        }

        const container = document.getElementById(containerId);
        let html = '';
        ports.forEach(p => {
            let badge = '';
            if(p.status==='open')    badge = `<span class="port-badge port-badge-open"><iconify-icon icon="solar:check-circle-bold" width="12"></iconify-icon> Open</span>`;
            else if(p.status==='limited') badge = `<span class="port-badge port-badge-limited"><iconify-icon icon="solar:danger-triangle-bold" width="12"></iconify-icon> Limited</span>`;
            else badge = `<span class="port-badge port-badge-closed"><iconify-icon icon="solar:forbidden-circle-bold" width="12"></iconify-icon> Closed</span>`;

            let weather = '';
            if(p.weatherData) {
                weather = `<span class="weather-pill">${p.weatherData.icon} ${p.weatherData.temperature}°C</span>
                           <span class="weather-pill">🌊 ${p.weatherData.waves||'N/A'}</span>
                           <span class="weather-pill">💨 ${p.weatherData.windSpeed}</span>`;
            } else {
                weather = `<iconify-icon icon="solar:cloud-sun-2-bold" width="14"></iconify-icon> Weather: Unknown`;
            }

            html += `
            <div class="port-card" data-id="${p.id}">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
                    <div class="port-icon"><iconify-icon icon="solar:anchor-bold-duotone" width="20"></iconify-icon></div>
                    <div class="relative-menu">
                        <button class="menu-btn" onclick="toggleMenu('${p.id}')"><iconify-icon icon="solar:menu-dots-bold" width="18"></iconify-icon></button>
                        <div id="dropdown-${p.id}" class="dropdown-menu">
                            <button onclick="openEditModal('${p.id}','${p.name.replace(/'/g,"\\'")}','${p.type}','${p.status}',${p.lat},${p.lng},'${p.location||''}')" class="dropdown-item">
                                <iconify-icon icon="solar:pen-bold" width="14"></iconify-icon> Edit Port
                            </button>
                            <button onclick="togglePortStatus('${p.id}')" class="dropdown-item">
                                <iconify-icon icon="solar:refresh-circle-bold" width="14"></iconify-icon> Toggle Status
                            </button>
                            <button onclick="deletePort('${p.id}')" class="dropdown-item danger">
                                <iconify-icon icon="solar:trash-bin-trash-bold" width="14"></iconify-icon> Delete Port
                            </button>
                        </div>
                    </div>
                </div>
                <h4 style="font-weight:600;font-size:15px;margin-bottom:6px;color:var(--color-text-dark);">${p.name}</h4>
                <div class="weather-text" style="margin-bottom:14px;">${weather}</div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1.5px solid var(--color-border);">
                    ${badge}
                    <button onclick="togglePortStatus('${p.id}')" class="update-btn">Update</button>
                </div>
            </div>`;
        });
        container.innerHTML = html;
    }

    // ---- Load More Ports ----
    async function loadMorePorts() {
        if (!lastVisibleId) return;
        const overlay = document.getElementById('loadingOverlay');
        overlay.classList.add('active');
        try {
            const r = await fetch(`/api/ports/load-more?lastId=${lastVisibleId}`);
            const data = await r.json();
            if (data.ports && data.ports.length > 0) {
                const grid = document.getElementById('ports-grid');
                const temp = document.createElement('div');
                temp.innerHTML = grid.innerHTML; // existing
                data.ports.forEach(p => {
                    let badge = '';
                    if(p.status==='open') badge=`<span class="port-badge port-badge-open"><iconify-icon icon="solar:check-circle-bold" width="12"></iconify-icon> Open</span>`;
                    else if(p.status==='limited') badge=`<span class="port-badge port-badge-limited"><iconify-icon icon="solar:danger-triangle-bold" width="12"></iconify-icon> Limited</span>`;
                    else badge=`<span class="port-badge port-badge-closed"><iconify-icon icon="solar:forbidden-circle-bold" width="12"></iconify-icon> Closed</span>`;
                    let wh = p.weatherData
                        ? `<span class="weather-pill">${p.weatherData.icon} ${p.weatherData.temperature}°C</span><span class="weather-pill">🌊 ${p.weatherData.waves||'N/A'}</span><span class="weather-pill">💨 ${p.weatherData.windSpeed}</span>`
                        : `<iconify-icon icon="solar:cloud-sun-2-bold" width="14"></iconify-icon> Weather: Unknown`;
                    grid.innerHTML += `
                    <div class="port-card" data-id="${p.id}">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
                            <div class="port-icon"><iconify-icon icon="solar:anchor-bold-duotone" width="20"></iconify-icon></div>
                            <div class="relative-menu">
                                <button class="menu-btn" onclick="toggleMenu('${p.id}')"><iconify-icon icon="solar:menu-dots-bold" width="18"></iconify-icon></button>
                                <div id="dropdown-${p.id}" class="dropdown-menu">
                                    <button onclick="openEditModal('${p.id}','${p.name.replace(/'/g,"\\'")}','${p.type}','${p.status}',${p.lat},${p.lng},'${p.location||''}')" class="dropdown-item"><iconify-icon icon="solar:pen-bold" width="14"></iconify-icon> Edit Port</button>
                                    <button onclick="togglePortStatus('${p.id}')" class="dropdown-item"><iconify-icon icon="solar:refresh-circle-bold" width="14"></iconify-icon> Toggle Status</button>
                                    <button onclick="deletePort('${p.id}')" class="dropdown-item danger"><iconify-icon icon="solar:trash-bin-trash-bold" width="14"></iconify-icon> Delete Port</button>
                                </div>
                            </div>
                        </div>
                        <h4 style="font-weight:600;font-size:15px;margin-bottom:6px;color:var(--color-text-dark);">${p.name}</h4>
                        <div class="weather-text" style="margin-bottom:14px;">${wh}</div>
                        <div style="display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1.5px solid var(--color-border);">
                            ${badge}<button onclick="togglePortStatus('${p.id}')" class="update-btn">Update</button>
                        </div>
                    </div>`;
                });
                if (data.lastVisible) {
                    lastVisibleId = data.lastVisible.id;
                } else {
                    document.getElementById('loadMoreContainer').style.display = 'none';
                }
                const rc = document.getElementById('resultCount');
                rc.innerText = parseInt(rc.innerText) + data.ports.length;
            }
        } catch(e) {
            showToast('Error loading more ports', 'error');
        } finally {
            overlay.classList.remove('active');
        }
    }

    // ---- Toggle Port Status ----
    async function togglePortStatus(id) {
        const card = document.querySelector(`.port-card[data-id="${id}"]`);
        if (!card) return;
        const badge = card.querySelector('.port-badge');
        const dd = document.getElementById('dropdown-'+id);
        if (dd) dd.classList.remove('show');
        const btn = event.currentTarget;
        if (btn) btn.disabled = true;
        try {
            const r = await fetch(`/api/ports/${id}/toggle-status`, { method: 'POST', headers: {'Content-Type':'application/json'} });
            if (r.ok) {
                const data = await r.json();
                const s = data.status;
                badge.className = `port-badge port-badge-${s}`;
                badge.innerHTML = getStatusIcon(s) + ' ' + s.charAt(0).toUpperCase() + s.slice(1);
                showToast('Port status updated', 'success');
            } else {
                showToast('Error updating port status', 'error');
            }
        } catch(e) {
            showToast('Error updating port status', 'error');
        } finally {
            if (btn) btn.disabled = false;
        }
    }

    function getStatusIcon(s) {
        if (s==='open')    return '<iconify-icon icon="solar:check-circle-bold" width="12"></iconify-icon>';
        if (s==='limited') return '<iconify-icon icon="solar:danger-triangle-bold" width="12"></iconify-icon>';
        return '<iconify-icon icon="solar:forbidden-circle-bold" width="12"></iconify-icon>';
    }

    // ---- Delete Port ----
    async function deletePort(id) {
        if (!confirm('Delete this port? This cannot be undone.')) return;
        try {
            const r = await fetch(`/admin/ports/${id}/delete`, { method: 'POST' });
            if (r.redirected || r.ok) {
                showToast('Port deleted', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else { showToast('Error deleting port', 'error'); }
        } catch(e) { showToast('Failed to delete port', 'error'); }
    }

    // ---- Dropdown toggle ----
    function toggleMenu(id) {
        document.querySelectorAll('.dropdown-menu').forEach(m => { if(m.id!=='dropdown-'+id) m.classList.remove('show'); });
        document.getElementById('dropdown-'+id).classList.toggle('show');
    }
    document.addEventListener('click', e => {
        if (!e.target.closest('.relative-menu')) {
            document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
        }
    });

    // ---- Add Modal ----
    function openAddModal() {
        document.getElementById('addPortForm').reset();
        document.getElementById('addPortModal').classList.add('active');
    }
    function closeAddModal() { document.getElementById('addPortModal').classList.remove('active'); }

    // ---- Edit Modal ----
    function openEditModal(id, name, type, status, lat, lng, location) {
        const form = document.getElementById('editPortForm');
        form.action = `/admin/ports/${id}/update`;
        document.getElementById('editName').value     = name;
        document.getElementById('editLocation').value = (location && location!=='undefined') ? location : '';
        document.getElementById('editStatus').value   = status;
        document.getElementById('editType').value     = type;
        document.getElementById('editLat').value      = lat;
        document.getElementById('editLng').value      = lng;
        document.getElementById('editPortModal').classList.add('active');
        toggleMenu(id);
    }
    function closeEditModal() { document.getElementById('editPortModal').classList.remove('active'); }

    // Close modals on overlay click
    document.getElementById('addPortModal').addEventListener('click', e => { if(e.target===e.currentTarget) closeAddModal(); });
    document.getElementById('editPortModal').addEventListener('click', e => { if(e.target===e.currentTarget) closeEditModal(); });
    document.addEventListener('keydown', e => { if(e.key==='Escape'){ closeAddModal(); closeEditModal(); }});

    // ---- Toast ----
    function showToast(msg, type) {
        const t  = document.getElementById('toast');
        const ic = document.getElementById('toast-icon');
        document.getElementById('toast-message').innerText = msg;
        t.className  = 'toast ' + (type||'info');
        ic.className = 'toast-icon ' + (type||'info');
        if(type==='success') ic.setAttribute('icon','solar:check-circle-bold');
        else if(type==='error') ic.setAttribute('icon','solar:danger-circle-bold');
        else ic.setAttribute('icon','solar:info-circle-bold');
        t.classList.add('show');
        setTimeout(()=>t.classList.remove('show'), 3500);
    }
</script>
</body>
</html>