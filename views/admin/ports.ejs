<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #FFD7C4;
            color: #2D2F31;
        }

        /* Minimal scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: #BD77FF; border-radius: 2px; }

        /* Sidebar */
        .sidebar {
            background-color: #FFF4B5;
            border-right: 1px solid #87A2FF;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.625rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            color: #65676B;
            transition: all 0.15s ease;
        }

        .nav-item:hover {
            background-color: #FEC1A0;
            color: #2D2F31;
        }

        .nav-item.active {
            background-color: #87A2FF;
            color: white;
        }

        /* User profile */
        .user-profile {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            border-top: 1px solid #87A2FF;
        }

        .user-avatar {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 9999px;
            border: 2px solid #99123D;
        }

        /* Header */
        .header {
            background-color: rgba(255, 244, 181, 0.8);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid #87A2FF;
        }

        /* Search input */
        .search-input {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 30px;
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            font-size: 0.875rem;
            width: 16rem;
        }

        .search-input:focus {
            outline: none;
            border-color: #BD77FF;
        }

        /* Port Cards */
        .port-card {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 16px;
            padding: 1.5rem;
            transition: all 0.15s ease;
        }

        .port-card:hover {
            border-color: #BD77FF;
        }

        .port-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 12px;
            background-color: #C4D7FF;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #99123D;
        }

        /* Status badges */
        .badge {
            padding: 0.375rem 0.75rem;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
        }

        .badge-open {
            background-color: #62AE7D;
            color: white;
        }

        .badge-limited {
            background-color: #FEC1A0;
            color: #2D2F31;
            border: 1px solid #99123D;
        }

        .badge-closed {
            background-color: #99123D;
            color: white;
        }

        /* Update button */
        .update-btn {
            background-color: #C4D7FF;
            color: #65676B;
            padding: 0.375rem 1rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid #87A2FF;
            transition: all 0.15s ease;
        }

        .update-btn:hover {
            background-color: #FEC1A0;
            border-color: #99123D;
            color: #2D2F31;
        }

        /* Menu button */
        .menu-btn {
            color: #65676B;
            padding: 0.25rem;
            border-radius: 6px;
            transition: all 0.15s ease;
        }

        .menu-btn:hover {
            color: #99123D;
            background-color: #FEC1A0;
        }

        /* Notification button */
        .notification-btn {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 9999px;
            border: 1px solid #87A2FF;
            background-color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #65676B;
            position: relative;
            transition: all 0.15s ease;
        }

        .notification-btn:hover {
            background-color: #FEC1A0;
        }

        .notification-badge {
            position: absolute;
            top: 0.5rem;
            right: 0.75rem;
            width: 0.375rem;
            height: 0.375rem;
            background-color: #99123D;
            border-radius: 50%;
        }

        /* Weather text */
        .weather-text {
            color: #65676B;
            font-size: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .weather-text iconify-icon {
            color: #87A2FF;
        }

        /* Toast */
        .toast {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 250px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 sidebar hidden lg:flex flex-col">
        <!-- Brand -->
        <div class="h-16 flex items-center px-6 border-b border-[#87A2FF]">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded flex items-center justify-center" style="background-color: #87A2FF;">
                    <iconify-icon icon="solar:wheel-angle-bold" width="14" style="color: white;"></iconify-icon>
                </div>
                <span class="font-semibold text-base" style="color: #99123D;">AquaRoute</span>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-0.5">
            <a href="/admin/dashboard" class="nav-item">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon>
                Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon>
                Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item active">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon>
                Port Management
            </a>
            <a href="/admin/logs" class="nav-item">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon>
                Audit Logs
            </a>
        </nav>

        <!-- User -->
        <div class="user-profile">
            <img src="https://ui-avatars.com/api/?name=<%= user.name.replace(' ', '+') %>&background=99123D&color=fff" class="user-avatar">
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate"><%= user.name %></p>
                <p class="text-xs" style="color: #65676B;"><%= user.role || 'Admin' %></p>
            </div>
            <a href="/logout" style="color: #99123D;">
                <iconify-icon icon="solar:logout-2-bold" width="18"></iconify-icon>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col min-w-0">
        
        <!-- Header -->
        <header class="h-16 header flex items-center justify-between px-6">
            <div class="flex items-center gap-4 lg:hidden">
                <button style="color: #87A2FF;"><iconify-icon icon="solar:hamburger-menu-bold" width="20"></iconify-icon></button>
                <span class="font-semibold" style="color: #99123D;">AquaRoute</span>
            </div>
            
            <div>
                <h1 class="text-lg font-semibold" style="color: #2D2F31;">Port Management</h1>
                <p class="text-xs" style="color: #65676B;">Control port operations and advisories</p>
            </div>

            <div class="flex items-center gap-3">
                <button class="notification-btn">
                    <iconify-icon icon="solar:bell-bold" width="18"></iconify-icon>
                    <span class="notification-badge"></span>
                </button>
            </div>
        </header>

        <!-- Content -->
        <div class="flex-1 overflow-auto p-6">
            <div class="space-y-5 fade-in">
                <!-- Search Bar -->
                <div class="flex justify-between items-center">
                    <div class="relative">
                        <iconify-icon icon="solar:magnifer-linear" class="absolute left-3 top-1/2 -translate-y-1/2" style="color: #87A2FF; font-size: 0.875rem;"></iconify-icon>
                        <input type="text" id="port-search" onkeyup="filterPorts()" placeholder="Search ports..." class="search-input">
                    </div>
                </div>

                <!-- Ports Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="ports-grid">
                    <% ports.forEach(p => { %>
                    <div class="port-card" data-name="<%= p.name.toLowerCase() %>">
                        <div class="flex justify-between items-start mb-4">
                            <div class="port-icon">
                                <iconify-icon icon="solar:anchor-bold-duotone" width="20"></iconify-icon>
                            </div>
                            <button class="menu-btn">
                                <iconify-icon icon="solar:menu-dots-bold" width="18"></iconify-icon>
                            </button>
                        </div>
                        
                        <h4 class="font-semibold text-base mb-1" style="color: #2D2F31;"><%= p.name %></h4>
                        
                        <div class="weather-text mb-4">
                            <iconify-icon icon="solar:cloud-sun-2-bold" width="14"></iconify-icon>
                            Weather: <%= p.weather || 'Unknown' %>
                        </div>
                        
                        <div class="flex justify-between items-center pt-3 border-t border-[#87A2FF]">
                            <% if (p.status === 'open') { %>
                            <span class="badge badge-open">
                                <iconify-icon icon="solar:check-circle-bold" width="12"></iconify-icon>
                                Open
                            </span>
                            <% } else if (p.status === 'limited') { %>
                            <span class="badge badge-limited">
                                <iconify-icon icon="solar:danger-triangle-bold" width="12"></iconify-icon>
                                Limited
                            </span>
                            <% } else { %>
                            <span class="badge badge-closed">
                                <iconify-icon icon="solar:forbidden-circle-bold" width="12"></iconify-icon>
                                Closed
                            </span>
                            <% } %>
                            
                            <button onclick="togglePortStatus('<%= p.id %>')" class="update-btn">
                                Update
                            </button>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 right-4 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
        <div class="toast">
            <div id="toast-icon" style="color: #62AE7D;">
                <iconify-icon icon="solar:check-circle-bold" width="18"></iconify-icon>
            </div>
            <p id="toast-message" class="text-sm" style="color: #2D2F31;">Success</p>
        </div>
    </div>

    <script>
        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const message = document.getElementById('toast-message');
            
            message.innerText = msg;
            
            if(type === 'success') {
                icon.innerHTML = '<iconify-icon icon="solar:check-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#62AE7D';
            } else if(type === 'error') {
                icon.innerHTML = '<iconify-icon icon="solar:danger-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#99123D';
            } else {
                icon.innerHTML = '<iconify-icon icon="solar:info-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#BD77FF';
            }

            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        async function togglePortStatus(id) {
            try {
                const response = await fetch(`/api/ports/${id}/toggle-status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    location.reload();
                    showToast('Port status updated', 'success');
                }
            } catch (error) {
                showToast('Error updating port status', 'error');
            }
        }

        function filterPorts() {
            const input = document.getElementById('port-search').value.toLowerCase();
            const cards = document.querySelectorAll('[data-name]');
            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                card.style.display = name.includes(input) ? '' : 'none';
            });
        }
    </script>
</body>
</html>