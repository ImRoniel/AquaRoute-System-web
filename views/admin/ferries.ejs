<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #FFD7C4;
            color: #2D2F31;
        }

        /* Minimal scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: #BD77FF; border-radius: 2px; }

        /* Sidebar */
        .sidebar {
            background-color: #FFF4B5;
            border-right: 1px solid #87A2FF;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.625rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            color: #65676B;
            transition: all 0.15s ease;
        }

        .nav-item:hover {
            background-color: #FEC1A0;
            color: #2D2F31;
        }

        .nav-item.active {
            background-color: #87A2FF;
            color: white;
        }

        /* User profile */
        .user-profile {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            border-top: 1px solid #87A2FF;
        }

        .user-avatar {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 9999px;
            border: 2px solid #99123D;
        }

        /* Header */
        .header {
            background-color: rgba(255, 244, 181, 0.8);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid #87A2FF;
        }

        /* Status badges */
        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
        }

        .badge-on-time {
            background-color: #62AE7D;
            color: white;
        }

        .badge-delayed {
            background-color: #FEC1A0;
            color: #2D2F31;
            border: 1px solid #99123D;
        }

        .badge-suspended {
            background-color: #99123D;
            color: white;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background-color: currentColor;
            opacity: 0.8;
        }

        /* Table */
        .table-container {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 12px;
            overflow: hidden;
        }

        .table-header {
            background-color: #C4D7FF;
            padding: 0.75rem 1.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            color: #65676B;
            text-transform: uppercase;
            letter-spacing: 0.025em;
        }

        .table-row {
            border-bottom: 1px solid #87A2FF;
        }

        .table-row td {
            padding: 1rem 1.5rem;
            font-size: 0.875rem;
        }

        .table-row:hover {
            background-color: #FEC1A020;
        }

        /* Search input */
        .search-input {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 30px;
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            font-size: 0.875rem;
            width: 16rem;
        }

        .search-input:focus {
            outline: none;
            border-color: #BD77FF;
        }

        /* Buttons */
        .btn-primary {
            background-color: #87A2FF;
            color: white;
            padding: 0.5rem 1.25rem;
            border-radius: 30px;
            font-size: 0.875rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            border: 1px solid #87A2FF;
            transition: all 0.15s ease;
        }

        .btn-primary:hover {
            background-color: #BD77FF;
            border-color: #BD77FF;
        }

        .btn-filter {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 30px;
            padding: 0.5rem;
            color: #65676B;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s ease;
        }

        .btn-filter:hover {
            background-color: #FEC1A0;
            border-color: #99123D;
            color: #2D2F31;
        }

        /* Pagination */
        .page-btn {
            width: 2rem;
            height: 2rem;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
            color: #65676B;
            transition: all 0.15s ease;
        }

        .page-btn:hover {
            background-color: #FEC1A0;
            color: #2D2F31;
        }

        .page-btn.active {
            background-color: #87A2FF;
            color: white;
        }

        /* Action button */
        .action-btn {
            color: #65676B;
            padding: 0.5rem;
            border-radius: 8px;
            transition: all 0.15s ease;
        }

        .action-btn:hover {
            color: #99123D;
            background-color: #FEC1A0;
        }

        /* Notification button */
        .notification-btn {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 9999px;
            border: 1px solid #87A2FF;
            background-color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #65676B;
            position: relative;
            transition: all 0.15s ease;
        }

        .notification-btn:hover {
            background-color: #FEC1A0;
        }

        .notification-badge {
            position: absolute;
            top: 0.5rem;
            right: 0.75rem;
            width: 0.375rem;
            height: 0.375rem;
            background-color: #99123D;
            border-radius: 50%;
        }

        /* Toast */
        .toast {
            background-color: white;
            border: 1px solid #87A2FF;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 250px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 sidebar hidden lg:flex flex-col">
        <!-- Brand -->
        <div class="h-16 flex items-center px-6 border-b border-[#87A2FF]">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded flex items-center justify-center" style="background-color: #87A2FF;">
                    <iconify-icon icon="solar:wheel-angle-bold" width="14" style="color: white;"></iconify-icon>
                </div>
                <span class="font-semibold text-base" style="color: #99123D;">AquaRoute</span>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-0.5">
            <a href="/admin/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon>
                Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item <%= currentPage === 'ferries' ? 'active' : '' %>">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon>
                Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item <%= currentPage === 'ports' ? 'active' : '' %>">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon>
                Port Management
            </a>
            <a href="/admin/cargo" class="nav-item <%= currentPage === 'cargo' ? 'active' : '' %>">
                <iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon>
                Cargo Tracking
            </a>
            <a href="/admin/logs" class="nav-item <%= currentPage === 'logs' ? 'active' : '' %>">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon>
                Audit Logs
            </a>
            <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
                <iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon>
                Users
            </a>
        </nav>

        <!-- User -->
        <div class="user-profile">
            <img src="https://ui-avatars.com/api/?name=<%= user.name.replace(' ', '+') %>&background=99123D&color=fff" class="user-avatar">
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate"><%= user.name %></p>
                <p class="text-xs" style="color: #65676B;"><%= user.role || 'Admin' %></p>
            </div>
            <a href="/logout" style="color: #99123D;">
                <iconify-icon icon="solar:logout-2-bold" width="18"></iconify-icon>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col min-w-0">
        
        <!-- Header -->
        <header class="h-16 header flex items-center justify-between px-6">
            <div class="flex items-center gap-4 lg:hidden">
                <button style="color: #87A2FF;"><iconify-icon icon="solar:hamburger-menu-bold" width="20"></iconify-icon></button>
                <span class="font-semibold" style="color: #99123D;">AquaRoute</span>
            </div>
            
            <div>
                <h1 class="text-lg font-semibold" style="color: #2D2F31;">Ferry Management</h1>
                <p class="text-xs" style="color: #65676B;">Monitor and update vessel statuses</p>
            </div>

            <div class="flex items-center gap-3">
                <button class="notification-btn">
                    <iconify-icon icon="solar:bell-bold" width="18"></iconify-icon>
                    <span class="notification-badge"></span>
                </button>
            </div>
        </header>

        <!-- Content -->
        <div class="flex-1 overflow-auto p-6">
            <div class="space-y-5 fade-in">
                <!-- Action Bar -->
                <div class="flex flex-col md:flex-row justify-between md:items-center gap-4">
                    <div class="flex gap-2">
                        <div class="relative">
                            <iconify-icon icon="solar:magnifer-linear" class="absolute left-3 top-1/2 -translate-y-1/2" style="color: #87A2FF; font-size: 0.875rem;"></iconify-icon>
                            <input type="text" id="ferry-search" onkeyup="filterFerries()" placeholder="Search vessels..." class="search-input">
                        </div>
                        <button class="btn-filter">
                            <iconify-icon icon="solar:filter-bold" width="16"></iconify-icon>
                        </button>
                    </div>
                    <button onclick="showToast('Add ferry functionality coming soon!', 'info')" class="btn-primary">
                        <iconify-icon icon="solar:add-circle-bold" width="16"></iconify-icon>
                        Add New Ferry
                    </button>
                </div>

                <!-- Table -->
                <div class="table-container">
                    <div class="table-header">
                        Ferry Fleet Overview
                    </div>
                    <table class="w-full">
                        <thead>
                            <tr class="bg-[#C4D7FF20]">
                                <th class="px-6 py-3 text-left text-xs font-semibold" style="color: #65676B;">Vessel Name</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold" style="color: #65676B;">Route</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold" style="color: #65676B;">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold" style="color: #65676B;">ETA (Mins)</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold" style="color: #65676B;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="ferries-table-body">
                            <% ferries.forEach(f => { %>
                            <tr class="table-row" data-id="<%= f.id %>">
                                <td class="px-6 py-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #C4D7FF; color: #99123D;">
                                            <iconify-icon icon="solar:ship-bold-duotone" width="16"></iconify-icon>
                                        </div>
                                        <span class="font-medium"><%= f.name %></span>
                                    </div>
                                </td>
                                <td class="px-6 py-3" style="color: #65676B;"><%= f.route %></td>
                                <td class="px-6 py-3 cursor-pointer" onclick="toggleStatus('<%= f.id %>')">
                                    <% if (f.status === 'on_time') { %>
                                    <span class="badge badge-on-time">
                                        <span class="status-dot"></span> On Time
                                    </span>
                                    <% } else if (f.status === 'delayed') { %>
                                    <span class="badge badge-delayed">
                                        <span class="status-dot" style="background-color: #99123D;"></span> Delayed
                                    </span>
                                    <% } else { %>
                                    <span class="badge badge-suspended">
                                        <span class="status-dot"></span> Suspended
                                    </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-3" style="color: #65676B;"><%= f.eta %> min</td>
                                <td class="px-6 py-3 text-right">
                                    <button class="action-btn">
                                        <iconify-icon icon="solar:pen-bold" width="16"></iconify-icon>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    
                    <!-- Pagination -->
                    <div class="px-6 py-3 border-t border-[#87A2FF] flex items-center justify-between">
                        <span class="text-xs" style="color: #65676B;">Showing 1-5 of 12 vessels</span>
                        <div class="flex gap-1">
                            <button class="page-btn active">1</button>
                            <button class="page-btn">2</button>
                            <button class="page-btn">3</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 right-4 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
        <div class="toast">
            <div id="toast-icon" style="color: #62AE7D;">
                <iconify-icon icon="solar:check-circle-bold" width="18"></iconify-icon>
            </div>
            <p id="toast-message" class="text-sm" style="color: #2D2F31;">Success</p>
        </div>
    </div>

    <script>
        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const message = document.getElementById('toast-message');
            
            message.innerText = msg;
            
            if(type === 'success') {
                icon.innerHTML = '<iconify-icon icon="solar:check-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#62AE7D';
            } else if(type === 'error') {
                icon.innerHTML = '<iconify-icon icon="solar:danger-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#99123D';
            } else {
                icon.innerHTML = '<iconify-icon icon="solar:info-circle-bold" width="18"></iconify-icon>';
                icon.style.color = '#BD77FF';
            }

            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        async function toggleStatus(id) {
            try {
                const response = await fetch(`/api/ferries/${id}/toggle-status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    location.reload();
                    showToast('Ferry status updated', 'success');
                }
            } catch (error) {
                showToast('Error updating status', 'error');
            }
        }

        function filterFerries() {
            const input = document.getElementById('ferry-search').value.toLowerCase();
            const rows = document.getElementById('ferries-table-body').getElementsByTagName('tr');
            for(let row of rows) {
                const txt = row.textContent.toLowerCase();
                row.style.display = txt.includes(input) ? '' : 'none';
            }
        }
    </script>
</body>
</html>