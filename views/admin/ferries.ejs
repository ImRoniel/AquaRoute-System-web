<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute</title>

    <!-- AquaRoute Maritime Theme -->
    <link rel="stylesheet" href="/css/admin-theme.css">

    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        .modal-overlay-bg {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(2px);
            z-index: 50;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-overlay-bg.active { display: flex; }

        .btn-icon-table {
            padding: 6px;
            border-radius: 6px;
            background: transparent;
            border: none;
            color: var(--color-text-medium);
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-icon-table:hover { background: var(--color-primary-light); color: var(--color-primary); }
        .btn-icon-table.btn-delete-table:hover { background: #fee2e2; color: #ef4444; }

        .filter-panel-popup {
            position: absolute;
            top: 44px; left: 0;
            width: 240px;
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-lg);
            padding: 16px;
            box-shadow: var(--shadow-lg);
            z-index: 100;
            display: none;
        }
        .filter-panel-popup.open { display: block; }

        .vessel-icon {
            width: 32px; height: 32px;
            border-radius: 8px;
            background: var(--color-primary-light);
            display: flex; align-items: center; justify-content: center;
            color: var(--color-primary);
        }
    </style>
</head>
<body>
<div class="app-shell fade-in">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand">
            <div class="brand-icon"><img src="/aquaRoute_logo.svg" alt="AquaRoute Logo" style="width:16px; height:16px; filter:brightness(0) invert(1);"></div>
            <span class="brand-name">AquaRoute</span>
        </div>
        </div>
        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon> Dashboard
            </a>
            <a href="/admin/ferries" class="nav-item <%= currentPage === 'ferries' ? 'active' : '' %>">
                <iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon> Ferry Management
            </a>
            <a href="/admin/ports" class="nav-item <%= currentPage === 'ports' ? 'active' : '' %>">
                <iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon> Port Management
            </a>
            <a href="/admin/cargo" class="nav-item <%= currentPage === 'cargo' ? 'active' : '' %>">
                <iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon> Cargo Tracking
            </a>
            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs" class="nav-item <%= currentPage === 'logs' ? 'active' : '' %>">
                <iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon> Audit Logs
            </a>
            <a href="/admin/users" class="nav-item <%= currentPage === 'users' ? 'active' : '' %>">
                <iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon> Users
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user ? user.name.replace(' ', '+') : 'Admin' %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user ? user.name : 'Admin User' %></div>
                    <div class="user-role"><%= user ? (user.role || 'Admin') : 'Administrator' %></div>
                </div>
                <a href="/logout" class="logout-btn">
                    <iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon>
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <header class="top-header">
            <div class="page-title">
                <h1>Ferry Management</h1>
                <p>Monitor and update vessel statuses</p>
            </div>
            <div class="header-actions">
                <button onclick="openAddModal()" class="btn btn-primary">
                    <iconify-icon icon="solar:add-circle-bold" width="16"></iconify-icon>
                    Add New Ferry
                </button>
                <button class="icon-btn" title="Notifications">
                    <iconify-icon icon="solar:bell-bold" width="17"></iconify-icon>
                </button>
            </div>
        </header>

        <div class="page-content">

            <!-- Flash Messages -->
            <% if (query && query.error) { %>
            <div class="panel" style="border-left:4px solid var(--color-error);background:var(--color-error-bg);padding:12px 16px;margin-bottom:16px;">
                <span style="color:var(--color-error);font-weight:500;">Error: <%= query.error %></span>
            </div>
            <% } %>
            <% if (query && query.success) { %>
            <div class="panel" style="border-left:4px solid var(--color-success);background:var(--color-success-bg);padding:12px 16px;margin-bottom:16px;">
                <span style="color:var(--color-success);font-weight:500;"><%= query.success %></span>
            </div>
            <% } %>

            <!-- Table Panel -->
            <div class="panel slide-up">
                <div class="panel-header">
                    <span class="panel-title">
                        <iconify-icon icon="solar:ship-bold-duotone"></iconify-icon>
                        Fleet Overview
                    </span>
                    <div style="display:flex;gap:8px;align-items:center;">
                        <!-- Search -->
                        <div style="position:relative;">
                            <iconify-icon icon="solar:magnifer-linear" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--color-text-light);pointer-events:none;"></iconify-icon>
                            <input type="text" id="ferry-search" onkeyup="filterFerries()"
                                   placeholder="Search vessels…"
                                   style="
                                     border:1.5px solid var(--color-border);
                                     border-radius:var(--radius-pill);
                                     padding:8px 12px 8px 32px;
                                     font-size:13px;
                                     font-family:var(--font-sans);
                                     outline:none;
                                     width:200px;
                                     background:var(--color-surface);
                                     color:var(--color-text-dark);
                                   ">
                        </div>
                        <!-- Filter -->
                        <div style="position:relative;">
                            <button class="btn btn-secondary" id="filter-btn" onclick="toggleFilterPanel()" style="padding:8px 12px;">
                                <iconify-icon icon="solar:filter-bold" width="14"></iconify-icon>
                                Filter
                            </button>
                            <div id="filter-panel" class="filter-panel-popup">
                                <p style="font-weight:600;font-size:13px;margin-bottom:12px;color:var(--color-text-dark);">Filter Vessels</p>
                                <form action="/admin/ferries" method="GET">
                                    <div class="form-group">
                                        <label class="form-label">Status</label>
                                        <select name="status" class="form-control">
                                            <option value="">All Statuses</option>
                                            <option value="on_time" <%= query.status === 'on_time' ? 'selected' : '' %>>On Time</option>
                                            <option value="delayed" <%= query.status === 'delayed' ? 'selected' : '' %>>Delayed</option>
                                            <option value="suspended" <%= query.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Route</label>
                                        <input type="text" name="route" value="<%= query.route || '' %>" placeholder="e.g., Manila - Cebu" class="form-control">
                                    </div>
                                    <div style="display:flex;gap:8px;margin-top:4px;">
                                        <a href="/admin/ferries" class="btn btn-secondary" style="flex:1;text-align:center;">Clear</a>
                                        <button type="submit" class="btn btn-primary" style="flex:1;">Apply</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Vessel Name</th>
                                <th>Route</th>
                                <th>Status</th>
                                <th>ETA (Mins)</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="ferries-table-body">
                            <% ferries.forEach(f => { %>
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="vessel-icon">
                                            <iconify-icon icon="solar:ship-bold-duotone" width="16"></iconify-icon>
                                        </div>
                                        <span style="font-weight:600;"><%= f.name %></span>
                                    </div>
                                </td>
                                <td class="secondary"><%= f.route %></td>
                                <td style="cursor:pointer;" onclick="toggleStatus('<%= f.id %>')">
                                    <% if (f.status === 'on_time' || f.status === 'active') { %>
                                        <span class="badge badge-on-time">
                                            <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;opacity:.8;"></span>
                                            On Time
                                        </span>
                                    <% } else if (f.status === 'delayed') { %>
                                        <span class="badge badge-delayed">
                                            <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;opacity:.8;"></span>
                                            Delayed
                                        </span>
                                    <% } else { %>
                                        <span class="badge badge-suspended">
                                            <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;opacity:.8;"></span>
                                            <%= f.status || 'Suspended' %>
                                        </span>
                                    <% } %>
                                </td>
                                <td class="secondary"><%= f.eta %> min</td>
                                <td style="text-align:right;">
                                    <button class="btn-icon-table"
                                            data-ferry="<%= encodeURIComponent(JSON.stringify(f)) %>"
                                            onclick="openEditModal(this.dataset.ferry)"
                                            title="Edit">
                                        <iconify-icon icon="solar:pen-bold" width="16"></iconify-icon>
                                    </button>
                                    <button class="btn-icon-table btn-delete-table"
                                            onclick="confirmDeleteFerry('<%= f.id %>', '<%= f.name %>', this)"
                                            title="Delete">
                                        <iconify-icon icon="solar:trash-bin-trash-bold" width="16"></iconify-icon>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div><!-- /page-content -->
    </div><!-- /main-content -->
</div><!-- /app-shell -->

<!-- Add Ferry Modal -->
<div id="addFerryModal" class="modal-overlay-bg">
    <div class="modal" style="max-width:620px;">
        <div class="modal-header">
            <span class="modal-title">
                <iconify-icon icon="solar:ship-bold-duotone"></iconify-icon>
                Add New Ferry
            </span>
            <button type="button" onclick="closeAddModal()" class="modal-close">
                <iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon>
            </button>
        </div>
        <form method="POST" action="/admin/ferries/add" id="addFerryForm">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label" for="name">Vessel Name *</label>
                    <input type="text" class="form-control" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="route">Route * (e.g., Manila - Cebu)</label>
                    <input type="text" class="form-control" id="route" name="route" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="speed_knots">Speed (knots)</label>
                        <input type="number" class="form-control" id="speed_knots" name="speed_knots" value="20" min="1" step="1">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="eta">ETA (minutes)</label>
                        <input type="number" class="form-control" id="eta" name="eta" value="60" min="1" step="1">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="status">Status</label>
                    <select class="form-control" id="status" name="status">
                        <option value="on_time">On Time</option>
                        <option value="delayed">Delayed</option>
                        <option value="suspended">Suspended</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                </div>
                <p style="font-weight:600;font-size:13px;margin:12px 0 4px;color:var(--color-text-dark);">Origin Port (Point A) *</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="pointA_lat">Latitude</label>
                        <input type="number" step="any" class="form-control" id="pointA_lat" name="pointA_lat" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="pointA_lng">Longitude</label>
                        <input type="number" step="any" class="form-control" id="pointA_lng" name="pointA_lng" required>
                    </div>
                </div>
                <p style="font-weight:600;font-size:13px;margin:12px 0 4px;color:var(--color-text-dark);">Destination Port (Point B) *</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="pointB_lat">Latitude</label>
                        <input type="number" step="any" class="form-control" id="pointB_lat" name="pointB_lat" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="pointB_lng">Longitude</label>
                        <input type="number" step="any" class="form-control" id="pointB_lng" name="pointB_lng" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="source">Data Source</label>
                    <input type="text" class="form-control" id="source" name="source" value="manual">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeAddModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Ferry</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Ferry Modal -->
<div id="editFerryModal" class="modal-overlay-bg">
    <div class="modal" style="max-width:620px;">
        <div class="modal-header">
            <span class="modal-title">
                <iconify-icon icon="solar:pen-bold"></iconify-icon>
                Edit Ferry
            </span>
            <button type="button" onclick="closeEditModal()" class="modal-close">
                <iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon>
            </button>
        </div>
        <form method="POST" id="editFerryForm">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label" for="edit_name">Vessel Name *</label>
                    <input type="text" class="form-control" id="edit_name" name="name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="edit_route">Route *</label>
                    <input type="text" class="form-control" id="edit_route" name="route" required>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="edit_speed">Speed (knots)</label>
                        <input type="number" class="form-control" id="edit_speed" name="speed_knots" min="1" step="1">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="edit_eta">ETA (minutes)</label>
                        <input type="number" class="form-control" id="edit_eta" name="eta" min="0" step="1">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="edit_status">Status</label>
                    <select class="form-control" id="edit_status" name="status">
                        <option value="on_time">On Time</option>
                        <option value="delayed">Delayed</option>
                        <option value="suspended">Suspended</option>
                    </select>
                </div>
                <p style="font-weight:600;font-size:13px;margin:12px 0 4px;color:var(--color-text-dark);">Origin Port (Point A)</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="edit_pointA_lat">Latitude</label>
                        <input type="number" step="any" class="form-control" id="edit_pointA_lat" name="pointA_lat">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="edit_pointA_lng">Longitude</label>
                        <input type="number" step="any" class="form-control" id="edit_pointA_lng" name="pointA_lng">
                    </div>
                </div>
                <p style="font-weight:600;font-size:13px;margin:12px 0 4px;color:var(--color-text-dark);">Destination Port (Point B)</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label" for="edit_pointB_lat">Latitude</label>
                        <input type="number" step="any" class="form-control" id="edit_pointB_lat" name="pointB_lat">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="edit_pointB_lng">Longitude</label>
                        <input type="number" step="any" class="form-control" id="edit_pointB_lng" name="pointB_lng">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeEditModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    function openAddModal() {
        document.getElementById('addFerryModal').classList.add('active');
    }
    function closeAddModal() {
        document.getElementById('addFerryModal').classList.remove('active');
        document.getElementById('addFerryForm').reset();
    }
    function openEditModal(encodedFerry) {
        let ferry;
        try {
            ferry = JSON.parse(decodeURIComponent(encodedFerry));
        } catch (e) {
            showToast('Error loading ferry data', 'error');
            console.error('Failed to parse ferry data:', e);
            return;
        }
        const form = document.getElementById('editFerryForm');
        form.action = `/admin/ferries/${ferry.id}/update`;
        document.getElementById('edit_name').value = ferry.name || '';
        document.getElementById('edit_route').value = ferry.route || '';
        document.getElementById('edit_speed').value = ferry.speed_knots || 20;
        document.getElementById('edit_eta').value = ferry.eta || 0;
        document.getElementById('edit_status').value = ferry.status || 'on_time';
        document.getElementById('edit_pointA_lat').value = (ferry.pointA && ferry.pointA.lat) ? ferry.pointA.lat : (ferry.current_lat || '');
        document.getElementById('edit_pointA_lng').value = (ferry.pointA && ferry.pointA.lng) ? ferry.pointA.lng : (ferry.current_lng || '');
        document.getElementById('edit_pointB_lat').value = (ferry.pointB && ferry.pointB.lat) ? ferry.pointB.lat : '';
        document.getElementById('edit_pointB_lng').value = (ferry.pointB && ferry.pointB.lng) ? ferry.pointB.lng : '';
        document.getElementById('editFerryModal').classList.add('active');
    }
    function closeEditModal() {
        document.getElementById('editFerryModal').classList.remove('active');
    }
    function toggleFilterPanel() {
        document.getElementById('filter-panel').classList.toggle('open');
    }
    window.onclick = function(event) {
        const addM  = document.getElementById('addFerryModal');
        const editM = document.getElementById('editFerryModal');
        const fp    = document.getElementById('filter-panel');
        const fb    = document.getElementById('filter-btn');
        if (event.target === addM) closeAddModal();
        if (event.target === editM) closeEditModal();
        if (fp && fb && !fp.contains(event.target) && !fb.contains(event.target)) fp.classList.remove('open');
    };

    // Handle AJAX Form Submission
    document.getElementById('editFerryForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const form = this;
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerText;
        
        submitBtn.innerText = 'Saving...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                const result = await response.json();
                closeEditModal();
                showToast('Ferry updated successfully', 'success');
                // Reload page to briefly show changes (can be optimized to DOM update later if requested)
                setTimeout(() => location.reload(), 800);
            } else {
                const errorData = await response.json();
                showToast(errorData.error || 'Error updating ferry', 'error');
                submitBtn.innerText = originalText;
                submitBtn.disabled = false;
            }
        } catch (error) {
            console.error('Submit error:', error);
            showToast('Network error updating ferry', 'error');
            submitBtn.innerText = originalText;
            submitBtn.disabled = false;
        }
    });
    function showToast(msg, type) {
        const toast = document.getElementById('toast');
        const icon  = document.getElementById('toast-icon');
        const text  = document.getElementById('toast-message');
        text.innerText = msg;
        toast.className = 'toast ' + (type || 'info');
        icon.className  = 'toast-icon ' + (type || 'info');
        if (type === 'success') icon.setAttribute('icon', 'solar:check-circle-bold');
        else if (type === 'error') icon.setAttribute('icon', 'solar:danger-circle-bold');
        else icon.setAttribute('icon', 'solar:info-circle-bold');
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3500);
    }
    async function toggleStatus(id) {
        try {
            const r = await fetch(`/api/ferries/${id}/toggle-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
            if (r.ok) { location.reload(); }
            else { showToast('Error updating status', 'error'); }
        } catch(e) { showToast('Error updating status', 'error'); }
    }
    async function confirmDeleteFerry(id, name, btn) {
        if (!confirm(`Are you sure you want to delete ferry "${name}"? This action cannot be undone.`)) {
            return;
        }
        
        try {
            const response = await fetch(`/admin/ferries/${id}/delete`, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include'
            });

            if (response.ok) {
                showToast('Ferry deleted successfully', 'success');
                // Dynamic removal with animation
                const row = btn.closest('tr');
                if (row) {
                    row.style.transition = 'all 0.4s ease';
                    row.style.opacity = '0';
                    row.style.transform = 'translateX(20px)';
                    setTimeout(() => row.remove(), 400);
                }
            } else {
                const error = await response.json();
                showToast(error.error || 'Error deleting ferry', 'error');
                if (response.status === 401) {
                    setTimeout(() => window.location.href = '/login', 1500);
                }
            }
        } catch (error) {
            console.error('Delete error:', error);
            showToast('Network error while deleting ferry', 'error');
        }
    }
    function filterFerries() {
        const q    = document.getElementById('ferry-search').value.toLowerCase();
        const rows = document.getElementById('ferries-table-body').getElementsByTagName('tr');
        for (let row of rows) {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        }
    }
    <% if (typeof message !== 'undefined' && message) { %>
    window.onload = () => showToast('<%= message %>', 'success');
    <% } %>
</script>
</body>
</html>