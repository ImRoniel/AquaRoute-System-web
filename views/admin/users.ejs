<!-- views/admin/users.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - AquaRoute Admin</title>
    <link rel="stylesheet" href="/css/admin-theme.css">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .modal-overlay-bg { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); backdrop-filter:blur(2px); z-index:50; align-items:center; justify-content:center; padding:20px; }
        .modal-overlay-bg.active { display:flex; }
        .btn-icon { padding:6px; border-radius:6px; background:transparent; border:none; color:var(--color-text-medium); cursor:pointer; transition:all 0.15s; }
        .btn-icon:hover { background:var(--color-primary-light); color:var(--color-primary); }
        .btn-icon.danger:hover { background:var(--color-error-bg); color:var(--color-error); }
        .sbwrap { position:relative; max-width:340px; }
        .sbwrap .si { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--color-text-light); pointer-events:none; }
        .sbwrap input { width:100%; background:var(--color-surface); border:1.5px solid var(--color-border); border-radius:var(--radius-pill); padding:9px 14px 9px 36px; font-size:13px; outline:none; font-family:var(--font-sans); color:var(--color-text-dark); transition:all 0.2s; }
        .sbwrap input:focus { border-color:var(--color-primary); box-shadow:0 0 0 3px rgba(10,77,140,0.08); }
    </style>
</head>
<body>
<div class="app-shell fade-in">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><iconify-icon icon="solar:wheel-angle-bold" width="16" style="color:#fff"></iconify-icon></div>
            <span class="brand-name">AquaRoute</span>
        </div>
        <nav class="sidebar-nav">
            <span class="nav-section-label">Main</span>
            <a href="/admin/dashboard" class="nav-item <%= currentPage==='dashboard'?'active':'' %>"><iconify-icon icon="solar:widget-5-bold-duotone" width="18"></iconify-icon> Dashboard</a>
            <a href="/admin/ferries"   class="nav-item <%= currentPage==='ferries'?'active':'' %>"><iconify-icon icon="solar:ship-bold-duotone" width="18"></iconify-icon> Ferry Management</a>
            <a href="/admin/ports"     class="nav-item <%= currentPage==='ports'?'active':'' %>"><iconify-icon icon="solar:anchor-circle-bold-duotone" width="18"></iconify-icon> Port Management</a>
            <a href="/admin/cargo"     class="nav-item <%= currentPage==='cargo'?'active':'' %>"><iconify-icon icon="solar:box-bold-duotone" width="18"></iconify-icon> Cargo Tracking</a>
            <span class="nav-section-label" style="margin-top:8px;">System</span>
            <a href="/admin/logs"      class="nav-item <%= currentPage==='logs'?'active':'' %>"><iconify-icon icon="solar:clipboard-list-bold-duotone" width="18"></iconify-icon> Audit Logs</a>
            <a href="/admin/users"     class="nav-item <%= currentPage==='users'?'active':'' %>"><iconify-icon icon="solar:users-group-rounded-bold" width="18"></iconify-icon> Users</a>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <img src="https://ui-avatars.com/api/?name=<%= user ? user.name.replace(' ','+') : 'Admin' %>&background=0A4D8C&color=fff" alt="avatar">
                <div class="flex-1 truncate">
                    <div class="user-name truncate"><%= user ? user.name : 'Admin User' %></div>
                    <div class="user-role"><%= user ? (user.role||'Admin') : 'Administrator' %></div>
                </div>
                <a href="/logout" class="logout-btn"><iconify-icon icon="solar:logout-2-bold" width="16"></iconify-icon></a>
            </div>
        </div>
    </aside>

    <div class="main-content">
        <header class="top-header">
            <div class="page-title"><h1>User Management</h1><p>Manage system users and permissions</p></div>
            <div class="header-actions">
                <button onclick="openAddModal()" class="btn btn-primary"><iconify-icon icon="solar:add-circle-bold" width="16"></iconify-icon> Add User</button>
                <button class="icon-btn"><iconify-icon icon="solar:bell-bold" width="17"></iconify-icon></button>
            </div>
        </header>

        <div class="page-content">
            <div class="stat-grid mb-6" style="grid-template-columns:repeat(3,1fr);">
                <div class="stat-card primary slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:users-group-rounded-bold" width="20"></iconify-icon></div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value"><%= users ? users.length : 0 %></div>
                </div>
                <div class="stat-card info slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:shield-user-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Admins</div>
                    <div class="stat-value" style="color:var(--color-accent)">
                        <%= users ? users.filter(u => u.role==='admin'||u.role==='super_admin').length : 0 %>
                    </div>
                </div>
                <div class="stat-card success slide-up">
                    <div class="stat-icon"><iconify-icon icon="solar:user-bold-duotone" width="20"></iconify-icon></div>
                    <div class="stat-label">Regular Users</div>
                    <div class="stat-value success"><%= users ? users.filter(u => u.role==='user').length : 0 %></div>
                </div>
            </div>

            <div class="panel slide-up">
                <div class="panel-header">
                    <span class="panel-title">
                        <iconify-icon icon="solar:users-group-rounded-bold"></iconify-icon>
                        System Users
                        <span style="color:var(--color-text-light);font-weight:400;font-size:12px;">(<%= users ? users.length : 0 %> records)</span>
                    </span>
                    <div class="sbwrap">
                        <iconify-icon icon="solar:magnifer-linear" class="si"></iconify-icon>
                        <input type="text" id="userSearch" placeholder="Search users…" onkeyup="filterUsers()">
                    </div>
                </div>

                <% if (users && users.length > 0) { %>
                <div style="overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Username</th><th>Name</th><th>Role</th><th>Created</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            <% users.forEach(function(u) { %>
                            <tr data-username="<%= u.username.toLowerCase() %>" data-name="<%= u.name.toLowerCase() %>">
                                <td style="font-weight:600;font-family:monospace;font-size:12px;"><%= u.username %></td>
                                <td><%= u.name %></td>
                                <td>
                                    <% if (u.role==='super_admin') { %>
                                        <span class="badge badge-suspended">Super Admin</span>
                                    <% } else if (u.role==='admin') { %>
                                        <span class="badge badge-in-transit">Admin</span>
                                    <% } else { %>
                                        <span class="badge badge-docked">User</span>
                                    <% } %>
                                </td>
                                <td class="secondary"><%= new Date(u.created_at).toLocaleDateString() %></td>
                                <td style="text-align:right;">
                                    <% if (u.id !== user.id && u.id !== user.uid) { %>
                                    <button onclick="editUser('<%= u.id %>','<%= u.username %>','<%= u.name %>','<%= u.role %>')" class="btn-icon" title="Edit">
                                        <iconify-icon icon="solar:pen-bold" width="16"></iconify-icon>
                                    </button>
                                    <button onclick="deleteUser('<%= u.id %>','<%= u.username %>')" class="btn-icon danger" title="Delete">
                                        <iconify-icon icon="solar:trash-bin-trash-bold" width="16"></iconify-icon>
                                    </button>
                                    <% } else { %>
                                    <span style="font-size:11px;color:var(--color-text-light);">Current User</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div style="padding:48px;text-align:center;color:var(--color-text-light);">
                    <iconify-icon icon="solar:users-group-rounded-bold" width="48"></iconify-icon>
                    <p style="margin-top:8px;font-weight:600;">No users found</p>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div id="userModal" class="modal-overlay-bg">
    <div class="modal">
        <form id="userForm" method="POST">
            <div class="modal-header">
                <span class="modal-title"><iconify-icon icon="solar:user-plus-bold"></iconify-icon><span id="modalTitle">Add New User</span></span>
                <button type="button" onclick="closeModal()" class="modal-close"><iconify-icon icon="solar:close-circle-bold" width="18"></iconify-icon></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="userId" name="id">
                <div class="form-group">
                    <label class="form-label" for="username">Username / Email</label>
                    <input type="email" class="form-control" id="username" name="username" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input type="password" class="form-control" id="password" name="password">
                    <p style="font-size:11px;color:var(--color-text-light);margin-top:4px;">Leave blank to keep current password when editing</p>
                </div>
                <div class="form-group">
                    <label class="form-label" for="name">Full Name</label>
                    <input type="text" class="form-control" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="role">Role</label>
                    <select class="form-control" id="role" name="role" required>
                        <option value="user">User</option>
                        <option value="admin">Admin</option>
                        <option value="super_admin">Super Admin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="closeModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save User</button>
            </div>
        </form>
    </div>
</div>

<div id="toast" class="toast">
    <iconify-icon id="toast-icon" width="18"></iconify-icon>
    <span id="toast-message" class="toast-message">Success</span>
</div>

<script>
    function openAddModal(){document.getElementById('modalTitle').textContent='Add New User';document.getElementById('userForm').action='/admin/users/add';document.getElementById('userId').value='';document.getElementById('username').value='';document.getElementById('username').disabled=false;document.getElementById('password').value='';document.getElementById('password').required=true;document.getElementById('name').value='';document.getElementById('role').value='user';document.getElementById('role').disabled=false;document.getElementById('userModal').classList.add('active');}
    function editUser(id,username,name,role){document.getElementById('modalTitle').textContent='Edit User';document.getElementById('userForm').action='/admin/users/'+id+'/update';document.getElementById('userId').value=id;document.getElementById('username').value=username;document.getElementById('username').disabled=true;document.getElementById('password').value='';document.getElementById('password').required=false;document.getElementById('name').value=name;document.getElementById('role').value=role;document.getElementById('role').disabled=(role==='user');document.getElementById('userModal').classList.add('active');}
    function closeModal(){document.getElementById('userModal').classList.remove('active');document.getElementById('username').disabled=false;document.getElementById('role').disabled=false;document.getElementById('password').required=true;}
    function deleteUser(id,username){if(confirm('Delete user '+username+'?')){var f=document.createElement('form');f.method='POST';f.action='/admin/users/'+id+'/delete';document.body.appendChild(f);f.submit();}}
    function filterUsers(){var q=document.getElementById('userSearch').value.toLowerCase();var rows=document.getElementById('usersTableBody').getElementsByTagName('tr');for(var i=0;i<rows.length;i++){var un=rows[i].getAttribute('data-username');var nm=rows[i].getAttribute('data-name');rows[i].style.display=(un.includes(q)||nm.includes(q))?'':'none';}}
    function showToast(msg,type){const t=document.getElementById('toast');const ic=document.getElementById('toast-icon');document.getElementById('toast-message').innerText=msg;t.className='toast '+(type||'info');ic.className='toast-icon '+(type||'info');if(type==='success')ic.setAttribute('icon','solar:check-circle-bold');else if(type==='error')ic.setAttribute('icon','solar:danger-circle-bold');else ic.setAttribute('icon','solar:info-circle-bold');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}
    <% if (typeof message !== 'undefined' && message) { %>
    window.onload=()=>showToast('<%= message %>','success');
    <% } %>
    document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});
</script>
</body>
</html>